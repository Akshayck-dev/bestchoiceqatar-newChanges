                const mobileDrawer = document.getElementById("mobileDrawer");
                const servicesDrawer = document.getElementById("servicesDrawer");
                const navOverlay = document.getElementById("navbar-overlay");
                const servOverlay = document.getElementById("servicesDrawerOverlay");
                const menuBtn = document.getElementById("menuBtn");

                mobileDrawer && mobileDrawer.classList.remove("open");
                servicesDrawer && servicesDrawer.classList.remove("open");
                navOverlay && navOverlay.classList.remove("active");
                servOverlay && servOverlay.classList.remove("active");
                if (menuBtn) menuBtn.innerHTML = '<i class="bi bi-list"></i>';
                document.documentElement.style.overflow = "";
                console.log("v13.0: All drawers forced closed");
            }

            /* ── RIGHT MOBILE NAV DRAWER ── */
            function initMobileDrawer() {
                const menuBtn = document.getElementById("menuBtn");
                const drawer  = document.getElementById("mobileDrawer");
                const overlay = document.getElementById("navbar-overlay");
                if (!menuBtn || !drawer || !overlay) {
                    console.warn("v13.0 Mobile Drawer: missing element", { menuBtn, drawer, overlay });
                    return;
                }

                console.log("v13.0 Mobile Drawer Engine Active");

                function openMobileDrawer() {
                    // Close others first
                    const servicesDrawer = document.getElementById("servicesDrawer");
                    const servOverlay = document.getElementById("servicesDrawerOverlay");
                    servicesDrawer && servicesDrawer.classList.remove("open");
                    servOverlay && servOverlay.classList.remove("active");

                    drawer.classList.add("open");
                    overlay.classList.add("active");
                    menuBtn.innerHTML = '<i class="bi bi-x"></i>';
                    document.documentElement.style.overflow = "hidden";
                    menuBtn.setAttribute("aria-expanded", "true");
                    console.log("v13.0 Mobile Drawer Opened");
                }

                function toggleMobileDrawer() {
                    drawer.classList.contains("open") ? forceCloseAll() : openMobileDrawer();
                }

                menuBtn.onclick = function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    toggleMobileDrawer();
                };

                overlay.onclick = forceCloseAll;

                const closeBtn = document.getElementById("mobile-nav-close");
                if (closeBtn) closeBtn.onclick = forceCloseAll;

                // Dropdown toggles inside mobile drawer
                drawer.querySelectorAll(".dropdown > a").forEach(function(link) {
                    link.addEventListener("click", function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        var subMenu = this.nextElementSibling;
                        if (subMenu) {
                            subMenu.classList.toggle("dropdown-active");
                            // Toggle chevron icon
                            const icon = this.querySelector("i:last-child");
                            if (icon) {
                                icon.classList.toggle("bi-chevron-up");
                                icon.classList.toggle("bi-chevron-down");
                            }
                        }
                    });
                });
            }

            /* ── LEFT SERVICES DRAWER ── */
            function initServicesDrawer() {
                const openBtn  = document.getElementById("servicesDrawerBtn");
                const closeBtn = document.getElementById("servicesDrawerClose");
                const drawer   = document.getElementById("servicesDrawer");
                const overlay  = document.getElementById("servicesDrawerOverlay");
                if (!openBtn || !drawer || !overlay) return;

                console.log("v13.0 Services Drawer Engine Active");

                function openServicesDrawer() {
                    // Close Mobile Nav first
                    const mobileDrawer = document.getElementById("mobileDrawer");
                    const navOverlay = document.getElementById("navbar-overlay");
                    const menuBtn = document.getElementById("menuBtn");
                    mobileDrawer && mobileDrawer.classList.remove("open");
                    navOverlay && navOverlay.classList.remove("active");
                    if(menuBtn) menuBtn.innerHTML = '<i class="bi bi-list"></i>';

                    drawer.classList.add("open");
                    overlay.classList.add("active");
                    document.documentElement.style.overflow = "hidden";
                    openBtn.setAttribute("aria-expanded", "true");
                    console.log("v13.0 Services Drawer Opened");
                }

                openBtn.onclick  = function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    drawer.classList.contains("open") ? forceCloseAll() : openServicesDrawer();
                };
                overlay.onclick  = forceCloseAll;
                if (closeBtn) closeBtn.onclick = forceCloseAll;

                // ESC key to close all
                document.addEventListener("keydown", function(e) {
                    if (e.key === "Escape") forceCloseAll();
                });
            }

            // Boot both engines
            function boot() {
                initMobileDrawer();
                initServicesDrawer();
            }

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", boot);
            } else {
                boot();
            }
        })();
    </script>
</body>

</html>