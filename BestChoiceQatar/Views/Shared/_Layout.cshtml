    <script>
        (function() {
            "use strict";
            const lockClass = "lock-scroll";
            const html = document.documentElement;
            const body = document.body;

            function forceCloseAll() {
                const els = [
                    document.getElementById("mobileDrawer"),
                    document.getElementById("servicesDrawer"),
                    document.getElementById("navbar-overlay"),
                    document.getElementById("servicesDrawerOverlay"),
                    document.querySelector(".deskHamburgerOverlay")
                ];
                els.forEach(el => el && el.classList.remove("open", "active", "show"));
                const menuBtn = document.getElementById("menuBtn");
                if (menuBtn) menuBtn.innerHTML = '<i class="bi bi-list"></i>';
                html.classList.remove(lockClass);
                body.classList.remove(lockClass);
            }

            function openDrawer(drawerId, overlayId, btnId) {
                forceCloseAll();
                const drawer = document.getElementById(drawerId);
                const overlay = document.getElementById(overlayId);
                const btn = document.getElementById(btnId);
                drawer && drawer.classList.add("open");
                overlay && overlay.classList.add("active");
                if (btn && btnId === "menuBtn") btn.innerHTML = '<i class="bi bi-x"></i>';
                html.classList.add(lockClass);
                body.classList.add(lockClass);
            }

            const menuBtn = document.getElementById("menuBtn");
            if (menuBtn) menuBtn.onclick = () => {
                const drawer = document.getElementById("mobileDrawer");
                drawer.classList.contains("open") ? forceCloseAll() : openDrawer("mobileDrawer", "navbar-overlay", "menuBtn");
            };

            const servBtn = document.getElementById("servicesDrawerBtn");
            if (servBtn) servBtn.onclick = () => {
                const drawer = document.getElementById("servicesDrawer");
                drawer.classList.contains("open") ? forceCloseAll() : openDrawer("servicesDrawer", "servicesDrawerOverlay", "servicesDrawerBtn");
            };

            const deskBtn = document.getElementById("deskHamburgerBtn");
            if (deskBtn) deskBtn.onclick = () => {
                const overlay = document.querySelector(".deskHamburgerOverlay");
                if (overlay.classList.contains("open")) {
                    forceCloseAll();
                } else {
                    forceCloseAll();
                    overlay.classList.add("open");
                    html.classList.add(lockClass);
                    body.classList.add(lockClass);
                }
            };

            ["navbar-overlay", "servicesDrawerOverlay", "mobile-nav-close", "servicesDrawerClose", "deskHamburgerClose"].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.onclick = forceCloseAll;
            });

            // Extra support for custom close class
            document.querySelectorAll(".deskHamburgerClose").forEach(el => el.onclick = forceCloseAll);

            document.querySelectorAll("#mobileDrawer .dropdown > a").forEach(link => {
                link.onclick = function(e) {
                    e.preventDefault();
                    const sub = this.nextElementSibling;
                    if (sub) sub.classList.toggle("dropdown-active");
                };
            });

            document.addEventListener("keydown", e => { if (e.key === "Escape") forceCloseAll(); });
        })();
    </script>
