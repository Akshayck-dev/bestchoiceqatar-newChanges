    <!-- v4.0 Emergency Navigation Script -->
    <script>
        (function() {
            console.log("BestChoice Navigation v4.0 Logic Initialized");
            
            // Indestructible Toggle for Mobile
            document.addEventListener('click', function(e) {
                if(e.target.closest('.mobile-nav-toggle')) {
                    const nav = document.getElementById('navbar');
                    const overlay = document.getElementById('navbar-overlay');
                    nav.classList.toggle('navbar-mobile');
                    overlay.classList.toggle('active');
                    document.body.classList.toggle('mobile-nav-active');
                    document.body.classList.toggle('navbar-mobile-active');
                    
                    const btn = e.target.closest('.mobile-nav-toggle');
                    btn.classList.toggle('bi-list');
                    btn.classList.toggle('bi-x');
                    console.log("Mobile Nav Toggled:", nav.classList.contains('navbar-mobile'));
                }
                
                // Overlay click closure
                if(e.target.id === 'navbar-overlay' || e.target.id === 'mobile-nav-close') {
                    document.getElementById('navbar').classList.remove('navbar-mobile');
                    document.getElementById('navbar-overlay').classList.remove('active');
                    document.body.classList.remove('mobile-nav-active');
                    document.body.classList.remove('navbar-mobile-active');
                    const btn = document.querySelector('.mobile-nav-toggle');
                    btn.classList.add('bi-list');
                    btn.classList.remove('bi-x');
                }
            });
        })();
    </script>


