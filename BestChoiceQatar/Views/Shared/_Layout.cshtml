    <!-- v5.0 Emergency Force-Action Script -->
    <script>
        (function() {
            console.log("BestChoice Global Nav v5.0 Armed");
            
            function toggleMenu() {
                const nav = document.getElementById('navbar');
                const overlay = document.getElementById('navbar-overlay');
                const btn = document.querySelector('.mobile-nav-toggle');
                
                nav.classList.toggle('navbar-mobile');
                overlay.classList.toggle('active');
                document.body.classList.toggle('mobile-nav-active');
                
                if (nav.classList.contains('navbar-mobile')) {
                    if(btn) btn.innerHTML = '<i class="bi bi-x"></i>';
                    btn.classList.add('navbar-active-btn');
                    document.documentElement.style.overflow = 'hidden';
                } else {
                    if(btn) btn.innerHTML = '<i class="bi bi-list"></i>';
                    btn.classList.remove('navbar-active-btn');
                    document.documentElement.style.overflow = '';
                }
            }

            document.addEventListener('click', function(e) {
                if (e.target.closest('.mobile-nav-toggle')) {
                    toggleMenu();
                }
                
                if (e.target.id === 'navbar-overlay' || e.target.id === 'mobile-nav-close') {
                    if (document.getElementById('navbar').classList.contains('navbar-mobile')) {
                        toggleMenu();
                    }
                }
            });

            // Prevent horizontal overflow stretching
            window.addEventListener('load', function() {
                setTimeout(() => {
                    document.documentElement.style.overflowX = 'hidden';
                    document.body.style.overflowX = 'hidden';
                }, 100);
            });
        })();
    </script>
</body>

</html>