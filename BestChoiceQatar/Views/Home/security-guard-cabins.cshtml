@{
    ViewBag.Title = "Security Guard Cabins Qatar | Specialized Guard Houses";
    ViewBag.description = "Compact and functional security guard cabins and guard houses in Qatar. Features 360-degree visibility, high-density insulation, and climate control for security personnel.";
    ViewBag.keywords = "security cabins qatar, guard house doha, portable guard room, security units doha";
}

<main id="main" class="product-detail-page">

    <!-- Hero Section -->
    <section class="page-hero" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/Uploads/Products/Fabrication-1.jpg') center/cover no-repeat; padding: 120px 0 80px;">
        <div class="container text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold text-white mb-3">Security Guard Cabins</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center">
                    <li class="breadcrumb-item"><a href="/index" class="text-warning">Home</a></li>
                    <li class="breadcrumb-item"><a href="/portable-cabin-fabrication" class="text-warning">Fabrication</a></li>
                    <li class="breadcrumb-item active text-white" aria-current="page">Security Cabins</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Content Section -->
    <section class="py-5 bg-white">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <span class="section-label">Safety & Vigilance</span>
                    <h2 class="section-title">Compact & Functional Guard Houses</h2>
                    <p class="lead text-muted mt-4">Our specialized security cabins are engineered to provide maximum visibility and comfort for security personnel stationed at entry points.</p>
                    <p class="text-muted">Equipped with large glass windows for a 360-degree view and superior air conditioning, these units ensure peak performance and alertness for your safety teams.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Panoramic Windows</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Built-in Workdesk</li>
                            </ul>
                        </div>
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Anti-Slip Flooring</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Insulated Roof</li>
                            </ul>
                        </div>
                    </div>

                    <a href="/contact" class="btn-bc btn-bc-yellow mt-4">Order Guard Cabin <i class="bi bi-arrow-right ms-2"></i></a>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="position-relative text-center">
                        <img src="/Uploads/WhatsApp Image 2026-04-22 at 3.41.44 PM (2).jpeg" class="img-fluid shadow-lg" alt="Security Guard Cabin" style="border-radius: 20px; max-height: 450px;">
                        <div class="bg-primary-yellow position-absolute p-4 d-none d-md-block" style="bottom: -30px; right: -30px; border-radius: 15px; max-width: 250px;">
                            <h5 class="fw-bold mb-0 text-dark">High Visibility Design</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

<style>
    .section-label { font-size: 0.8rem; font-weight: 700; color: #ffcc00; text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 10px; }
    .section-title { font-size: 2.5rem; font-weight: 800; color: #111; line-height: 1.2; }
    .btn-bc { display: inline-flex; align-items: center; padding: 15px 35px; font-weight: 700; border-radius: 5px; transition: all 0.3s; text-decoration: none; text-transform: uppercase; font-size: 0.9rem; }
    .btn-bc-yellow { background: #ffcc00; color: #111; }
    .btn-bc-yellow:hover { background: #111; color: #ffcc00; }
</style>
