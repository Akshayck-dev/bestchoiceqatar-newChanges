@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Porto Cabin Offices in Qatar | BestChoice Contracting";
    ViewBag.description = "Premium Porto cabin offices and site office solutions in Qatar. Durable, relocatable, and custom-designed for industrial and construction sites.";
    ViewBag.keywords = "porto cabin offices Qatar, site office cabins Doha, modular office fabrication, portable cabins";

    BestChoiceQatar.Models.BestChoiceQatarEntities db = new BestChoiceQatar.Models.BestChoiceQatarEntities();
    var settings = db.Settings.FirstOrDefault();
}

<!-- ======= Premium UI Styles (Replicating Fabrication Page) ======= -->
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap');

    :root {
        --primary-yellow: #ffcc00;
        --dark-bg: #111111;
        --light-bg: #ffffff;
        --transition-smooth: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--light-bg);
        color: var(--dark-bg);
    }

    /* Hero Section - Matching Screenshot */
    .premium-hero {
        position: relative;
        height: 85vh;
        min-height: 600px;
        background: url('/Uploads/Products/cabin-1.jpg') center/cover no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.5) 100%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 900px;
    }

    .hero-label {
        color: var(--primary-yellow);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 2px;
        font-size: 0.9rem;
        display: block;
        margin-bottom: 20px;
    }

    .hero-title {
        font-weight: 900;
        font-size: clamp(3rem, 8vw, 6rem);
        line-height: 0.95;
        text-transform: uppercase;
        color: #fff;
        margin-bottom: 2rem;
        letter-spacing: -2px;
    }

    .hero-subtitle-container {
        border-left: 4px solid var(--primary-yellow);
        padding-left: 20px;
        margin-bottom: 3rem;
    }

    .hero-subtitle {
        font-size: clamp(1.1rem, 2vw, 1.4rem);
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.6;
        margin-bottom: 0;
    }

    .btn-premium {
        padding: 18px 40px;
        font-weight: 700;
        text-transform: uppercase;
        border-radius: 0;
        transition: var(--transition-smooth);
        letter-spacing: 1px;
    }

    .btn-yellow {
        background-color: var(--primary-yellow);
        color: #000;
        border: 2px solid var(--primary-yellow);
    }

    .btn-yellow:hover {
        background-color: transparent;
        color: var(--primary-yellow);
    }

    .btn-outline-white {
        background-color: transparent;
        color: #fff;
        border: 2px solid rgba(255, 255, 255, 0.3);
        margin-left: 15px;
    }

    .btn-outline-white:hover {
        border-color: #fff;
        background-color: #fff;
        color: #000;
    }

    /* Side Banner - Replicating "Creative Fabrication" */
    .side-banner {
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%) rotate(-90deg);
        transform-origin: left top;
        background: #e02b20; /* Red from screenshot */
        color: #fff;
        padding: 10px 30px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        z-index: 10;
        font-size: 0.9rem;
        display: none; /* Desktop only */
    }

    @@media (min-width: 992px) {
        .side-banner { display: block; left: 0; top: 60%; }
    }

    /* Trust Strip */
    .trust-strip {
        background: #000;
        padding: 40px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .trust-item h3 {
        color: var(--primary-yellow);
        font-weight: 800;
        font-size: 2.5rem;
        margin-bottom: 0;
    }

    .trust-item p {
        color: #888;
        text-transform: uppercase;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 1px;
    }

    /* Content Sections */
    section { padding: 100px 0; }
    
    .section-label {
        color: var(--primary-yellow);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 2px;
        font-size: 0.8rem;
        margin-bottom: 15px;
        display: block;
    }

    .section-title {
        font-weight: 900;
        font-size: clamp(2rem, 4vw, 3rem);
        text-transform: uppercase;
        letter-spacing: -1px;
        margin-bottom: 40px;
    }

    /* Feature Cards */
    .feature-card {
        padding: 40px;
        background: #f9f9f9;
        border-bottom: 4px solid #eee;
        transition: var(--transition-smooth);
        height: 100%;
    }

    .feature-card:hover {
        border-bottom-color: var(--primary-yellow);
        background: #fff;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        transform: translateY(-10px);
    }

    .feature-card i {
        font-size: 2.5rem;
        color: var(--primary-yellow);
        margin-bottom: 25px;
        display: block;
    }

    .feature-card h4 {
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 15px;
        font-size: 1.1rem;
    }

    /* Specifications Table */
    .spec-box {
        background: #111;
        color: #fff;
        padding: 60px;
        margin-top: 60px;
    }

    .spec-table {
        width: 100%;
        border-collapse: collapse;
    }

    .spec-table th, .spec-table td {
        padding: 15px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .spec-table th {
        color: var(--primary-yellow);
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        width: 30%;
        text-align: left;
    }

    .spec-table td {
        color: #ccc;
    }

    /* Gallery */
    .gallery-grid img {
        width: 100%;
        height: 300px;
        object-fit: cover;
        transition: var(--transition-smooth);
    }

    .gallery-grid img:hover { transform: scale(1.05); }

    /* Comparison Table Styles */
    .comparison-box {
        background: #fff;
        padding: 50px;
        border: 1px solid #eee;
        margin-top: 40px;
    }

    .comp-row {
        display: flex;
        align-items: center;
        padding: 20px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .comp-label {
        font-weight: 700;
        width: 30%;
        color: #888;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .comp-value {
        width: 35%;
        font-weight: 600;
    }

    .comp-value.best { color: #27ae60; }

    /* FAQ Accordion */
    .faq-item {
        margin-bottom: 20px;
        border: 1px solid #eee;
    }

    .faq-btn {
        width: 100%;
        text-align: left;
        padding: 20px 30px;
        background: #fff;
        border: none;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.95rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .faq-btn:after {
        content: '+';
        font-size: 1.5rem;
        color: var(--primary-yellow);
    }

    .faq-content {
        padding: 0 30px 20px;
        color: #666;
        line-height: 1.8;
        display: none;
    }

    /* Final CTA */
    .final-cta { background: var(--primary-yellow); text-align: center; padding: 120px 0; }
    .final-cta h2 { font-weight: 900; font-size: 4rem; text-transform: uppercase; line-height: 0.9; margin-bottom: 40px; }

    /* Swiper Gallery Carousel */
    .gallery-swiper {
        padding: 40px 0 80px;
        overflow: hidden;
    }

    .swiper-slide {
        height: 400px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        transition: var(--transition-smooth);
    }

    .swiper-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .swiper-slide:hover img {
        transform: scale(1.1);
    }

    .swiper-button-next, .swiper-button-prev {
        color: var(--primary-yellow);
        background: rgba(0,0,0,0.8);
        width: 50px;
        height: 50px;
        border-radius: 0;
    }

    .swiper-button-next:after, .swiper-button-prev:after {
        font-size: 1.2rem;
        font-weight: 900;
    }

    .swiper-pagination-bullet {
        background: #000;
        opacity: 0.2;
        width: 12px;
        height: 12px;
        border-radius: 0;
    }

    .swiper-pagination-bullet-active {
        background: var(--primary-yellow);
        opacity: 1;
        width: 30px;
    }

    @@media (max-width: 767.98px) {
        .swiper-slide { height: 300px; }
    }

    /* Product Showcase Cards */
    .product-showcase-card {
        position: relative;
        height: 400px;
        overflow: hidden;
        border-radius: 0;
        transition: var(--transition-smooth);
        cursor: pointer;
        display: block;
        text-decoration: none;
        border: 1px solid rgba(0,0,0,0.1);
    }

    .showcase-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .product-showcase-card:hover .showcase-img {
        transform: scale(1.1);
    }

    .showcase-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 40%, transparent 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 30px;
        transition: var(--transition-smooth);
    }

    .product-showcase-card:hover .showcase-overlay {
        background: linear-gradient(to top, rgba(215, 223, 33, 0.9) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
    }

    .showcase-title {
        color: #fff;
        font-weight: 800;
        font-family: 'Outfit', sans-serif;
        font-size: 1.4rem;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .product-showcase-card:hover .showcase-title {
        color: #111;
    }

    .showcase-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary-yellow);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }

    .product-showcase-card:hover .showcase-btn {
        color: #000;
    }
</style>

<main id="main">
    <!-- Side Banner -->
    <div class="side-banner">Creative Fabrication</div>

    <!-- Hero Section -->
    <section class="premium-hero p-0">
        <div class="hero-overlay"></div>
        <div class="container position-relative">
            <div class="hero-content" data-aos="fade-up">
                <span class="hero-label">Architecture & Fabrication</span>
                <h1 class="hero-title">Porto Cabin<br><span style="color: var(--primary-yellow)">Offices</span></h1>
                <div class="hero-subtitle-container">
                    <p class="hero-subtitle">Engineering premium modular spaces that redefine versatility and durability in Qatar's landscape. From <strong>rapid site offices in Doha</strong> to large-scale <strong>labor camps in Ras Laffan</strong>, we deliver engineered excellence.</p>
                </div>
                <div class="hero-actions">
                    <a href="#quote" class="btn btn-premium btn-yellow">Get a Quote</a>
                    <a href="tel:@settings.Mobile1" class="btn btn-premium btn-outline-white">Call Specialist</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Trust Strip -->
    <div class="trust-strip">
        <div class="container">
            <div class="row text-center">
                <div class="col-6 col-md-3 trust-item" data-aos="fade-up" data-aos-delay="100">
                    <h3>10+</h3>
                    <p>Years in Qatar</p>
                </div>
                <div class="col-6 col-md-3 trust-item" data-aos="fade-up" data-aos-delay="200">
                    <h3>FAST</h3>
                    <p>Turnaround Time</p>
                </div>
                <div class="col-6 col-md-3 trust-item" data-aos="fade-up" data-aos-delay="300">
                    <h3>BESPOKE</h3>
                    <p>Design Focus</p>
                </div>
                <div class="col-6 col-md-3 trust-item" data-aos="fade-up" data-aos-delay="400">
                    <h3>BEST</h3>
                    <p>Market Pricing</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Showcase grid -->
    <section class="bg-light">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="section-label">Specialist Solutions</span>
                <h2 class="section-title">Explore Our Cabin Range</h2>
            </div>
            <div class="row g-4 justify-content-center">
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                    <a href="/product/single-double-story-cabins" class="product-showcase-card">
                        <img src="/Content/assets/img/Products/cabin/cabin-1.jpg" class="showcase-img" alt="Single Story Cabin">
                        <div class="showcase-overlay">
                            <h3 class="showcase-title">Single & Double Story</h3>
                            <div class="showcase-btn">View Specification <i class="bi bi-arrow-right"></i></div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                    <a href="/product/labor-camps-accommodation" class="product-showcase-card">
                        <img src="/Content/assets/img/Products/cabin/cabin-2.jpg" class="showcase-img" alt="Labor Camp Qatar">
                        <div class="showcase-overlay">
                            <h3 class="showcase-title">Labor & Welfare Camps</h3>
                            <div class="showcase-btn">View Specification <i class="bi bi-arrow-right"></i></div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                    <a href="/product/security-guard-cabins" class="product-showcase-card">
                        <img src="/Content/assets/img/Products/cabin/cabin-3.jpg" class="showcase-img" alt="Security Cabins">
                        <div class="showcase-overlay">
                            <h3 class="showcase-title">Security & Guard Cabins</h3>
                            <div class="showcase-btn">View Specification <i class="bi bi-arrow-right"></i></div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                    <a href="/product/toilet-sanitary-cabins" class="product-showcase-card">
                        <img src="/Content/assets/img/Products/cabin/cabin-4.jpg" class="showcase-img" alt="Toilet Units">
                        <div class="showcase-overlay">
                            <h3 class="showcase-title">Toilet & Sanitary Units</h3>
                            <div class="showcase-btn">View Specification <i class="bi bi-arrow-right"></i></div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="500">
                    <a href="/product/container-office-cabins" class="product-showcase-card">
                        <img src="/Content/assets/img/Products/cabin/cabin-11.jpg" class="showcase-img" alt="Container Office">
                        <div class="showcase-overlay">
                            <h3 class="showcase-title">Container Office Cabins</h3>
                            <div class="showcase-btn">View Specification <i class="bi bi-arrow-right"></i></div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section>
        <div class="container">
            <div class="row g-5 align-items-center mb-5">
                <div class="col-lg-6" data-aos="fade-right">
                    <span class="section-label">Superior Standards</span>
                    <h2 class="section-title">Design and Installation of modular cabins</h2>
                    <p class="lead text-muted">We are experts in the design and installation of modular cabins for a range of office, welfare or accommodation applications.</p>
                    <ul class="list-unstyled mt-4">
                        <li class="mb-3 d-flex align-items-start"><i class="bi bi-check-circle-fill text-warning me-3 mt-1"></i> Customizable solutions for any site requirement (offices, mosques, canteens).</li>
                        <li class="mb-3 d-flex align-items-start"><i class="bi bi-check-circle-fill text-warning me-3 mt-1"></i> Locally manufactured in Qatar for rapid deployment within 7-10 days.</li>
                        <li class="mb-3 d-flex align-items-start"><i class="bi bi-check-circle-fill text-warning me-3 mt-1"></i> Fire-resistant specialized units for Oil & Gas industry (PIR/Rockwool insulation).</li>
                        <li class="mb-3 d-flex align-items-start"><i class="bi bi-check-circle-fill text-warning me-3 mt-1"></i> Suitable for G+1 and G+2 multi-story configurations to optimize footprint.</li>
                    </ul>
                </div>
                <div class="col-lg-12 mt-5" data-aos="fade-up">
                    <div class="swiper gallery-swiper">
                        <div class="swiper-wrapper">
                            @{
                                for (int j = 1; j <= 13; j++)
                                {
                                    string ext = (j == 5 || j == 6) ? "JPG" : "jpg";
                                    var imgUrl = Url.Content("~/Content/assets/img/Products/cabin/cabin-" + j + "." + ext);
                                    <div class="swiper-slide">
                                        <a href="@imgUrl" class="glightbox">
                                            <img src="@imgUrl" alt="Porta Cabin Office Qatar" loading="lazy">
                                        </a>
                                    </div>
                                }
                            }
                        </div>
                        <div class="swiper-pagination"></div>
                        <div class="swiper-button-next"></div>
                        <div class="swiper-button-prev"></div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-5">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card">
                        <i class="bi bi-snow"></i>
                        <h4>Climate Controlled</h4>
                        <p>Available with split or window type Air Conditioning as required to suit Qatar's heat.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card">
                        <i class="bi bi-lamp"></i>
                        <h4>Fully Fitted</h4>
                        <p>Full range of furniture and fittings available for turnkey office occupation.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card">
                        <i class="bi bi-pencil-square"></i>
                        <h4>Expert Drafting</h4>
                        <p>Full design, drawing, delivery and erection service available by our engineering team.</p>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-5">
                <div class="col-lg-6" data-aos="fade-right">
                    <span class="section-label">Why Modular?</span>
                    <h2 class="section-title">Porta Cabin vs Traditional</h2>
                    <p class="text-muted">Discover why top contractors in Mesaieed and Lusail prefer modular site mobilization for its speed and efficiency.</p>
                    
                    <div class="comparison-box">
                        <div class="comp-row">
                            <div class="comp-label">Feature</div>
                            <div class="comp-value">Traditional</div>
                            <div class="comp-value best">Modular</div>
                        </div>
                        <div class="comp-row">
                            <div class="comp-label">Timeline</div>
                            <div class="comp-value">6-12 Months</div>
                            <div class="comp-value best">7-14 Days</div>
                        </div>
                        <div class="comp-row">
                            <div class="comp-label">Foundation</div>
                            <div class="comp-value">Deep Piling</div>
                            <div class="comp-value best">Light Pad/Slab</div>
                        </div>
                        <div class="comp-row">
                            <div class="comp-label">Relocation</div>
                            <div class="comp-value">Impossible</div>
                            <div class="comp-value best">100% Mobile</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <span class="section-label">Industry Verticals</span>
                    <h2 class="section-title">Sector Applications</h2>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="feature-card p-4">
                                <i class="bi bi-hammer" style="font-size: 1.5rem;"></i>
                                <h5 class="fw-bold fs-6">COSTRUCTION</h5>
                                <p class="small mb-0">Project management offices and staff welfare centers for major Doha infrastructure.</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-card p-4">
                                <i class="bi bi-droplet-half" style="font-size: 1.5rem;"></i>
                                <h5 class="fw-bold fs-6">OIL & GAS</h5>
                                <p class="small mb-0">Explosion-proof and fire-rated units for remote energy sites in Qatar.</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-card p-4">
                                <i class="bi bi-hospital" style="font-size: 1.5rem;"></i>
                                <h5 class="fw-bold fs-6">HEALTHCARE</h5>
                                <p class="small mb-0">Sterile mobile clinics and first-aid stations for remote deployment.</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="feature-card p-4">
                                <i class="bi bi-calendar-event" style="font-size: 1.5rem;"></i>
                                <h5 class="fw-bold fs-6">EVENTS</h5>
                                <p class="small mb-0">VIP pods and registration kiosks for international exhibitions in Qatar.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="spec-box" data-aos="fade-up" id="quote">
                <div class="row">
                    <div class="col-lg-6">
                        <span class="section-label">Technical Data</span>
                        <h2 class="section-title" style="color:#fff;">Engineering Specs</h2>
                        <table class="spec-table">
                            <tr>
                                <th>Chassis</th>
                                <td>ISMC 100/150 Galvanized Steel Frame</td>
                            </tr>
                            <tr>
                                <th>Wall System</th>
                                <td>50mm/75mm/100mm Sandwich Panels</td>
                            </tr>
                            <tr>
                                <th>Insulation</th>
                                <td>High-density EPS or Fire-rated Rockwool</td>
                            </tr>
                            <tr>
                                <th>Electrical</th>
                                <td>Concealed wiring, compliant with Kahramaa</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-lg-6 mt-4 mt-lg-0">
                        <span class="section-label">Configuration</span>
                        <h2 class="section-title" style="color:#fff;">Interior Finish</h2>
                        <table class="spec-table">
                            <tr>
                                <th>Flooring</th>
                                <td>Heavy-duty Vinyl or Ceramic tiling</td>
                            </tr>
                            <tr>
                                <th>Ceiling</th>
                                <td>60x60 Gypsy or Aluminum Panels</td>
                            </tr>
