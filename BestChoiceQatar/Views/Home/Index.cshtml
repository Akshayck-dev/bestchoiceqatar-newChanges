@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Bestchoice Contracting | Premium Porta Cabin & Steel Fabrication in Qatar";
    ViewBag.description = "Leading porta cabin suppliers in Qatar. Specializing in high-quality portable office cabins, modular cabins, and prefab cabins Qatar since 2009.";
    ViewBag.keywords = "porta cabin Qatar, portable cabins Qatar, prefab cabins Qatar, steel fabrication Qatar, portable office cabin Qatar, modular cabins Qatar";

    BestChoiceQatar.Models.BestChoiceQatarEntities db = new BestChoiceQatar.Models.BestChoiceQatarEntities();
    var _sliders = (from b in db.Galleries
                    where b.IsDataActive && b.Category == "Slider"
                    select new { b.ID, b.Title, b.Description, b.Image }).ToList();
    var _services = (from b in db.Galleries
                     where b.IsDataActive && b.Category == "Service"
                     select new { b.ID, b.Title, b.Description, b.Image }).ToList();
    var _clients = (from b in db.Galleries
                    where b.IsDataActive && b.Category == "Clients"
                    select new { b.ID, b.Title, b.Image }).ToList();
    var settings = db.Settings.FirstOrDefault();
}




<style>
    :root {
        --primary-bc: #ffcc00; /* Signature Yellow */
        --dark-bc: #111111;
        --white-bc: #ffffff;
        --gray-bc: #f8f9fa;
        --font-headline: var(--font-heading);
        --font-body: var(--font-body);
    }

    /* Professional typography integration */
    .content p, .about-check-list li {
        font-size: var(--fs-base);
        line-height: var(--lh-body);
        color: #111;
        font-weight: 400;
    }
    :root {
        --transition-fast: all 0.3s ease;
        --transition-premium: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    body { font-family: var(--font-body); background-color: var(--white-bc); color: #333; overflow-x: hidden; width: 100%; position: relative; }
    html { overflow-x: hidden; width: 100%; }
    
    /* Global Image Safety */
    img { max-width: 100% !important; height: auto !important; }

    section { padding: 80px 0; overflow: hidden; width: 100%; }

    .h-black { font-weight: 900; text-transform: uppercase; font-family: var(--font-headline); letter-spacing: -1px; }
    .text-bc-yellow { color: var(--primary-bc); }

    /* Structural Grid Pattern Overlay */
    .structural-grid {
        background-image: radial-gradient(rgba(0,0,0,0.05) 1px, transparent 1px);
        background-size: 30px 30px;
    }

    /* 1. Hero Section - Refined Industrial Style */
    .hero-wrap { position: relative; height: 100vh; min-height: 800px; background: #000; display: flex; align-items: center; overflow: hidden; }
    
    .hero-swiper-premium { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; }
    .hero-swiper-premium .swiper-slide { height: 100%; width: 100%; overflow: hidden; opacity: 0; transition: opacity 1.2s ease; --slide-accent: #ffcc00; }
    .hero-swiper-premium .swiper-slide-active { opacity: 1; }
    
    /* Theme overrides for specific slides */
    .theme-lime { --slide-accent: #d4e157 !important; }

    .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transform: scale(1); transition: transform 8s linear; }
    .swiper-slide-active .hero-bg { transform: scale(1.15); }

    /* Professional Compound Overlay: Directional Gradient + Backdrop separator */
    .hero-overlay { 
        position: absolute; 
        inset: 0; 
        background: linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 40%, rgba(0,0,0,0) 80%); 
        z-index: 1; 
        backdrop-filter: brightness(0.9) contrast(1.1);
        -webkit-backdrop-filter: brightness(0.9) contrast(1.1);
        pointer-events: none;
    }
    
    .hero-content { 
        position: absolute; 
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        z-index: 10; 
        color: #fff !important; 
        text-align: left; 
        display: flex;
        align-items: center;
        justify-content: flex-start;
        width: 100%;
    }
    
    /* Animation Keyframes */
    @@keyframes heroFadeInUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .hero-label { 
        display: inline-block; 
        color: var(--slide-accent) !important; 
        font-weight: 800; 
        letter-spacing: 5px; 
        font-size: 0.85rem; 
        margin-bottom: 25px; 
        opacity: 0;
        text-transform: uppercase;
        border-left: 3px solid var(--slide-accent);
        padding-left: 12px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }
    .hero-h1 { 
        font-family: var(--font-headline); 
        font-size: var(--fs-h1); 
        font-weight: 900; 
        line-height: 1.0; 
        margin-bottom: 30px; 
        letter-spacing: -0.01em; 
        text-transform: uppercase;
        opacity: 0;
        color: #fff !important;
        text-shadow: 0 4px 30px rgba(0,0,0,0.8), 0 0 10px rgba(0,0,0,0.3);
    }
    .hero-subtext { 
        font-size: var(--fs-md); 
        color: #fff !important; 
        max-width: 750px; 
        margin: 0 0 45px; 
        line-height: 1.7; 
        font-weight: 400; 
        opacity: 0;
        text-shadow: 0 2px 15px rgba(0,0,0,0.8);
    }
    .hero-actions { opacity: 0; display: flex; gap: 20px; flex-wrap: wrap; justify-content: flex-start; }

    /* Trigger animations specifically for the active slide's inner content - Sharper Speed */
    .swiper-slide-active .hero-label { animation: heroFadeInUp 0.6s ease forwards 0.1s; }
    .swiper-slide-active .hero-h1 { animation: heroFadeInUp 0.6s ease forwards 0.25s; }
    .swiper-slide-active .hero-subtext { animation: heroFadeInUp 0.6s ease forwards 0.4s; }
    .swiper-slide-active .hero-actions { animation: heroFadeInUp 0.6s ease forwards 0.55s; }

    .btn-bc { padding: 14px 35px; border-radius: 0; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; transition: var(--transition-premium); display: inline-flex; align-items: center; gap: 10px; border: none; text-decoration: none; font-size: 0.85rem; }
    .btn-bc-yellow { background: var(--slide-accent, var(--primary-bc)); color: #000; }
    .btn-bc-yellow:hover { background: #fff; color: #000; transform: translateX(8px); }
    .btn-bc-outline { border: 2px solid rgba(255,255,255,0.8); color: #fff; background: rgba(255,255,255,0.05); backdrop-filter: blur(5px); }
    .btn-bc-outline:hover { border-color: var(--slide-accent, var(--primary-bc)); background: var(--slide-accent, var(--primary-bc)); color: #000; transform: translateX(8px); }
    
    .products-swiper-premium { padding-bottom: 80px !important; }
    .swiper-pagination-premium { bottom: 10px !important; }
    
    .btn-bc-small { padding: 10px 20px; font-size: 0.75rem; }

    .btn-bc, .card-link, .nav-link, .floating-item { 
        pointer-events: auto !important; 
        position: relative; 
        z-index: 25 !important; 
    }

    /* Vertical Pagination on Right */
    .hero-pagination {
        position: absolute;
        right: 50px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 20;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .hero-pagination .swiper-pagination-bullet {
        width: 12px;
        height: 12px;
        background: #fff;
        opacity: 0.3;
        margin: 0 !important;
        border-radius: 0;
        transition: all 0.4s ease;
    }
    .hero-pagination .swiper-pagination-bullet-active {
        background: var(--primary-bc);
        opacity: 1;
        height: 40px;
    }

    /* Mobile Responsiveness for Hero */
    @@media (max-width: 991.98px) {
        .hero-wrap { height: 100svh; min-height: 700px; padding: 100px 0 60px; }
        .hero-h1 { font-size: 2.5rem; margin-bottom: 20px; }
        .hero-subtext { font-size: 1rem; margin-bottom: 30px; }
        .hero-content { text-align: center; }
        .hero-subtext { margin: 0 auto 40px; }
        .hero-actions { justify-content: center; }
        .hero-pagination { 
            right: 20px; 
            top: auto; 
            bottom: 30px; 
            transform: none; 
            flex-direction: row;
        }
        .hero-pagination .swiper-pagination-bullet-active {
            width: 40px;
            height: 12px;
        }
        .hero-overlay { background: rgba(0,0,0,0.6); }
    }

    /* Corner Rivets Detail */
    .rivet { position: absolute; width: 8px; height: 8px; background: var(--primary-bc); z-index: 20; }
    .rivet-tl { top: 40px; left: 40px; }
    .rivet-tr { top: 40px; right: 40px; }
    .rivet-bl { bottom: 40px; left: 40px; }
    .rivet-br { bottom: 40px; right: 40px; }

    /* 2. About Section - Reference Layout */
    .about-img-stack { position: relative; }
    .about-img-top { width: 58%; aspect-ratio: 3/4; object-fit: cover; display: block; }
    .about-img-bottom { width: 58%; aspect-ratio: 3/4; object-fit: cover; position: absolute; right: 0; top: 30%; border: 6px solid #fff; }
    .about-badge { position: absolute; color: #fff; padding: 25px; line-height: 1.1; z-index: 20; display: flex; flex-direction: column; justify-content: center; align-items: start; min-width: 160px; aspect-ratio: 1/1; box-shadow: 0 15px 35px rgba(0,0,0,0.2); transition: var(--transition-premium); }
    .about-badge:hover { transform: scale(1.05) rotate(2deg); z-index: 30; }
    .about-badge-years { background: var(--primary-bc); color: #000; bottom: -15px; left: -15px; border: 5px solid #fff; }
    .about-badge-experts { background: #111; right: -15px; top: 15%; border: 5px solid #fff; }
    .about-badge .badge-num { font-size: 3rem; font-weight: 900; font-family: var(--font-headline); display: inline-block; line-height: 1; letter-spacing: -2px; }
    .about-badge .badge-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; display: block; margin-top: 8px; opacity: 0.9; line-height: 1.3; }
    .about-check-list { list-style: none; padding: 0; margin: 0; }
    .about-check-list li { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid #f0f0f0; font-weight: 600; color: #333; }
    .about-check-list li:last-child { border-bottom: none; }
    .about-check-list li span.material-symbols-outlined { color: var(--primary-bc); background: #fff8cc; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }

    /* 3. Benefits Section */
    .benefits-section { background: #f9f9f9; }
    .benefit-item { display: flex; align-items: flex-start; gap: 20px; padding: 30px; background: #fff; border: 1px solid #eee; height: 100%; transition: var(--transition-premium); }
    .benefit-item:hover { 
        border-color: var(--primary-bc); 
        box-shadow: 0 15px 40px rgba(255, 204, 0, 0.15); 
        transform: translateY(-8px); 
    }
    .benefit-icon { flex-shrink: 0; width: 64px; height: 64px; background: #fff8cc; display: flex; align-items: center; justify-content: center; border-radius: 0; border: 2px solid var(--primary-bc); }
    .benefit-icon span { font-size: 2rem; color: var(--primary-bc); }
    .benefit-title { font-weight: 900; font-family: var(--font-headline); margin-bottom: 8px; font-size: var(--fs-md); color: #000; }
    .benefit-desc { font-size: var(--fs-base); color: #111; margin-bottom: 0; line-height: 1.5; font-weight: 500; }

    /* 4. Price Calculator Section - Industrial Premium */
    .calc-section { background: #0a0a0a; color: #fff; padding: 100px 0; position: relative; overflow: hidden; }
    .calc-section::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(255,204,0,0.03) 0%, transparent 70%); pointer-events: none; }
    .calc-card { background: rgba(30, 30, 30, 0.6); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); padding: 50px; max-width: 800px; margin: 0 auto; position: relative; box-shadow: 0 40px 80px rgba(0,0,0,0.5); }
    .calc-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 60px; background: var(--primary-bc); box-shadow: 0 0 20px var(--primary-bc); }
    
    .calc-label { font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2.5px; color: rgba(255,255,255,0.8); margin-bottom: 12px; display: block; }
    .calc-select { width: 100%; padding: 18px 25px; background: rgba(0,0,0,0.4); color: #fff; border: 1px solid rgba(255,255,255,0.1); font-family: var(--font-body); font-size: 1.05rem; appearance: none; -webkit-appearance: none; cursor: pointer; transition: var(--transition-fast); }
    .calc-select:focus { outline: none; border-color: var(--primary-bc); background: rgba(0,0,0,0.6); }

    .qty-wrap { display: flex; align-items: center; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); }
    .qty-btn { width: 60px; height: 60px; background: transparent; color: var(--primary-bc); border: none; font-size: 1.5rem; font-weight: 300; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: var(--transition-fast); }
    .qty-btn:hover { background: var(--primary-bc); color: #000; }
    .qty-input { flex: 1; height: 60px; background: transparent; color: #fff; border: none; font-size: 1.25rem; font-weight: 800; text-align: center; font-family: var(--font-body); }
    .qty-input:focus { outline: none; }
    /* Remove arrows from number input */
    .qty-input::-webkit-outer-spin-button, .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

    .price-display { padding: 30px; background: rgba(255, 204, 0, 0.03); border: 1px solid rgba(255, 204, 0, 0.2); display: flex; align-items: center; justify-content: space-between; margin-top: 10px; position: relative; overflow: hidden; }
    .price-display::after { content: ''; position: absolute; bottom: 0; right: 0; width: 60px; height: 60px; background: linear-gradient(135deg, transparent 50%, rgba(255,204,0,0.1) 50%); }
    .price-amount { font-size: 3.2rem; font-weight: 900; color: var(--primary-bc); font-family: var(--font-headline); line-height: 1; text-shadow: 0 0 30px rgba(255,204,0,0.2); }
    .price-currency { font-size: 0.9rem; color: rgba(255,255,255,0.7); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; display: block; }
    
    .calc-note { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 15px; line-height: 1.5; font-style: italic; }
    .calc-cta { margin-top: 40px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @@media (max-width: 576px) { .calc-cta { grid-template-columns: 1fr; } .price-amount { font-size: 2.5rem; } }

    /* 5. Services Section */
    .service-img-wrap { height: 260px; overflow: hidden; }
    .service-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; }
    .service-card:hover .service-img { transform: scale(1.1); }
    .service-body { padding: 40px; }
    .service-card:hover { transform: translateY(-15px); box-shadow: 0 40px 80px rgba(0,0,0,0.08); border-color: var(--primary-bc); }
    .service-link { font-weight: 800; font-size: 0.85rem; color: var(--primary-bc); text-transform: uppercase; letter-spacing: 2px; }

    /* 5. Product Cards */
    .prod-card { background: #fff; border: 1px solid #eee; overflow: hidden; height: 100%; display: flex; flex-direction: column; transition: var(--transition-premium); }
    .prod-card:hover { 
        transform: translateY(-10px); 
        box-shadow: 0 30px 60px rgba(0,0,0,0.12), 0 0 25px rgba(255, 204, 0, 0.08); 
        border-color: var(--primary-bc); 
    }
    .prod-img-wrap { height: 240px; overflow: hidden; }
    .prod-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
    .prod-card:hover .prod-img { transform: scale(1.08); }
    .prod-body { padding: 28px 30px; flex: 1; display: flex; flex-direction: column; }
    .prod-title { font-family: var(--font-headline); font-weight: 800; font-size: var(--fs-md); margin-bottom: 12px; color: #111; }
    .prod-desc { font-size: var(--fs-base); color: #666; line-height: 1.7; flex: 1; margin-bottom: 20px; }
    .prod-read-more { display: inline-flex; align-items: center; gap: 6px; font-weight: 800; font-size: 0.85rem; color: #000; text-decoration: none; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid var(--primary-bc); padding-bottom: 2px; transition: var(--transition-fast); }
    .prod-read-more:hover { color: var(--primary-bc); gap: 10px; }
    .prod-read-more .material-symbols-outlined { font-size: 1rem; }

    /* 5b. Product Card - Image Overlay Style (Style 2) */
    .prod-card-overlay { position: relative; overflow: hidden; height: 320px; cursor: pointer; }
    .prod-card-overlay img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; display: block; }
    .prod-card-overlay:hover img { transform: scale(1.08); }
    .prod-overlay-caption { position: absolute; bottom: 0; left: 0; right: 0; background: #fff; padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; transition: background 0.3s ease; border-top: 3px solid var(--primary-bc); }
    .prod-card-overlay:hover .prod-overlay-caption { background: var(--primary-bc); }
    .prod-overlay-title { font-family: var(--font-headline); font-weight: 800; font-size: 1.1rem; color: #111; margin: 0; }
    .prod-overlay-arrow { width: 36px; height: 36px; background: #111; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.3s ease; }
    .prod-card-overlay:hover .prod-overlay-arrow { background: #fff; }
    .prod-overlay-arrow .material-symbols-outlined { color: #fff; font-size: 1.1rem; transition: color 0.3s; }
    .prod-card-overlay:hover .prod-overlay-arrow .material-symbols-outlined { color: #111; }

    /* 6. Why Choose Us Section */
    .feature-box { border-left: 4px solid var(--primary-bc); padding: 20px 30px; background: var(--gray-bc); height: 100%; }
    .feature-box h4 { font-weight: 800; font-family: var(--font-headline); margin-bottom: 10px; }

    /* 7. Work With Us Banner */
    .work-banner { position: relative; background: #1a2035; padding: 90px 0; overflow: hidden; text-align: center; }
    .work-banner-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.2; }
    .work-banner-content { position: relative; z-index: 10; }
    .work-banner h2 { font-size: var(--fs-h1); font-weight: 800; color: #fff; font-family: var(--font-headline); letter-spacing: -0.01em; margin-bottom: 35px; }
    .btn-bc-work { display: inline-block; padding: 16px 50px; background: var(--primary-bc); color: #000; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; font-size: 0.95rem; text-decoration: none; transition: var(--transition-premium); border: 2px solid var(--primary-bc); }
    .btn-bc-work:hover { background: transparent; color: #fff; }

    .process-item { position: relative; padding-left: 35px; border-left: 1px solid #ddd; margin-bottom: 40px; }
    .process-num { position: absolute; left: -18px; top: 0; width: 35px; height: 35px; background: var(--primary-bc); color: #000; display: flex; align-items: center; justify-content: center; font-weight: 900; border: 4px solid #fff; }

    /* 4. Testimonials */
    .testi-card { background: #1a1a1a; padding: 50px; border: 1px solid #333; height: 100%; position: relative; }
    .testi-card i { color: var(--primary-bc); font-size: 2rem; margin-bottom: 25px; display: block; }
    .testi-card p { font-size: 1.15rem; color: #ccc; font-style: italic; line-height: 1.8; }

    /* 5. Icon/Project Strip */
    .icon-strip { background: var(--gray-bc); border-top: 1px solid #eee; border-bottom: 1px solid #eee; padding: 60px 0; }
    .icon-box { text-align: center; }
    .icon-box span { font-size: 3.5rem; color: #000; margin-bottom: 20px; display: block; transition: var(--transition-fast); }
    .icon-box:hover span { color: var(--primary-bc); transform: scale(1.1); }
    .icon-box h5 { font-weight: 800; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 2px; }

    /* 6. Final CTA Exact Code Integration */
    .cta-industrial { position: relative; background: #000; padding: 160px 0; overflow: hidden; }
    .cta-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.45; }
    .cta-content-wrap { position: relative; z-index: 10; padding: 0 15px; }
    .cta-h2 { font-size: var(--fs-h1); font-weight: 800; letter-spacing: -0.02em; }

    /* --- COMPREHENSIVE MOBILE RESPONSIVENESS --- */
    @@media (max-width: 991.98px) {
        section { padding: 60px 0; }
        .hero-wrap { min-height: 100vh; height: auto; padding: 120px 0 80px; }
        .hero-h1 { font-size: 3.5rem; }
        .about-badge { padding: 15px 20px; }
        .about-badge .badge-num { font-size: 2rem; }
        .calc-card { padding: 30px 20px; }
    }

    /* Premium Redesign for Products Section */
    #products.premium-section {
        background: #0a0a0a;
        background: radial-gradient(circle at center, #151515 0%, #0a0a0a 100%);
        padding: 50px 0;
        color: #fff;
    }


    .premium-subtitle {
        color: var(--primary-bc);
        text-transform: uppercase;
        letter-spacing: 5px;
        font-weight: 800;
        font-size: 0.85rem;
        margin-bottom: 15px;
        display: block;
    }
    .premium-title {
        font-family: var(--font-headline);
        font-weight: 800;
        font-size: var(--fs-h2);
        line-height: 1.2;
        margin-bottom: 20px;
    }
    .premium-desc {
        color: rgba(255,255,255,0.6);
        max-width: 650px;
        margin: 0 auto 30px;
        font-size: var(--fs-base);
        line-height: 1.6;
    }

    .products-swiper-premium {
        padding: 10px 0 40px;
        overflow: visible; /* Allow slides to peek */
    }
    
    .premium-card {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        aspect-ratio: 2.4/1;
        background: #111;
        transition: var(--transition-premium);
        border: 1px solid rgba(255,255,255,0.05);
        opacity: 0.4;
        transform: scale(0.9);
    }


    
    /* Highlight the active center slide */
    .swiper-slide-active .premium-card {
        opacity: 1;
        transform: scale(1.05);
        box-shadow: 0 30px 60px rgba(0,0,0,0.5), 0 0 20px rgba(255, 204, 0, 0.1);
        border-color: rgba(255, 204, 0, 0.3);
    }

    .card-img-wrap {
        width: 100%;
        height: 100%;
        position: relative;
    }
    .card-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }
    .premium-card:hover img {
        transform: scale(1.1);
    }

    .card-overlay {
