@{
    ViewBag.Title = "Portable Toilets Qatar | High Hygiene Ablution Units";
    ViewBag.description = "Premium portable toilets and ablution blocks for construction sites and events in Qatar. Easy clean, durable, and high-hygiene modular units in Doha.";
    ViewBag.keywords = "portable toilets qatar, ablution block doha, mobile toilet qatar, sanitary units doha";
}

<main id="main" class="product-detail-page">

    <!-- Hero Section -->
    <section class="page-hero" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/Uploads/Products/Fabrication-2.jpg') center/cover no-repeat; padding: 120px 0 80px;">
        <div class="container text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold text-white mb-3">Portable Toilets & Ablution</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center">
                    <li class="breadcrumb-item"><a href="/index" class="text-warning">Home</a></li>
                    <li class="breadcrumb-item"><a href="/portable-cabin-fabrication" class="text-warning">Fabrication</a></li>
                    <li class="breadcrumb-item active text-white" aria-current="page">Portable Toilets</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Content Section -->
    <section class="py-5 bg-white">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6 order-lg-2" data-aos="fade-left">
                    <span class="section-label">Hygiene & Comfort</span>
                    <h2 class="section-title">High-Standard Sanitary Solutions</h2>
                    <p class="lead text-muted mt-4">We provide high-hygiene portable toilet units and comprehensive ablution blocks designed for long-term site deployment across Qatar.</p>
                    <p class="text-muted">Our sanitary units feature easy-clean PVC or ceramic finishes, heavy-duty plumbing, and efficient ventilation to maintain a clean environment for your workforce.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Durable Plumbing</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Anti-Bacterial Panels</li>
                            </ul>
                        </div>
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Exhaust Ventilation</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Water Tank Options</li>
                            </ul>
                        </div>
                    </div>

                    <a href="/contact" class="btn-bc btn-bc-yellow mt-4">Inquire Now <i class="bi bi-arrow-right ms-2"></i></a>
                </div>
                <div class="col-lg-6 order-lg-1" data-aos="fade-right">
                    <div class="position-relative text-center">
                        <img src="/Uploads/WhatsApp Image 2026-04-22 at 3.41.43 PM.jpeg" class="img-fluid shadow-lg" alt="Portable Toilet Unit" style="border-radius: 20px;">
                        <div class="bg-primary-yellow position-absolute p-4 d-none d-md-block" style="top: -30px; left: -30px; border-radius: 15px; max-width: 250px;">
                            <h5 class="fw-bold mb-0 text-dark">Hygienic & Durable</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

<style>
    .section-label { font-size: 0.8rem; font-weight: 700; color: #ffcc00; text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 10px; }
    .section-title { font-size: 2.5rem; font-weight: 800; color: #111; line-height: 1.2; }
    .btn-bc { display: inline-flex; align-items: center; padding: 15px 35px; font-weight: 700; border-radius: 5px; transition: all 0.3s; text-decoration: none; text-transform: uppercase; font-size: 0.9rem; }
    .btn-bc-yellow { background: #ffcc00; color: #111; }
    .btn-bc-yellow:hover { background: #111; color: #ffcc00; }
</style>
