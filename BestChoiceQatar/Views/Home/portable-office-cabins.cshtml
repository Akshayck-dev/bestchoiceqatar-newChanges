@{
    ViewBag.Title = "Portable Office Cabins Qatar | Premium Site Office Solutions";
    ViewBag.description = "BestChoice Qatar provides high-quality portable office cabins for construction sites and corporate use. Custom-built, climate-controlled, and durable office units in Doha.";
    ViewBag.keywords = "portable office cabins qatar, site office doha, porta cabin office, modular office qatar";
}

<main id="main" class="product-detail-page">

    <!-- Hero Section -->
    <section class="page-hero" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/Uploads/Products/cabin-1.jpg') center/cover no-repeat; padding: 120px 0 80px;">
        <div class="container text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold text-white mb-3">Portable Office Cabins</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center">
                    <li class="breadcrumb-item"><a href="/index" class="text-warning">Home</a></li>
                    <li class="breadcrumb-item"><a href="/portable-cabin-fabrication" class="text-warning">Fabrication</a></li>
                    <li class="breadcrumb-item active text-white" aria-current="page">Office Cabins</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Content Section -->
    <section class="py-5 bg-white">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <span class="section-label">Executive Workspace</span>
                    <h2 class="section-title">Premium Portable Office Solutions</h2>
                    <p class="lead text-muted mt-4">We design and manufacture high-end portable office cabins that provide a professional workspace environment on any project site in Qatar.</p>
                    <p class="text-muted">Our office units are built with reinforced steel frames and superior insulation, ensuring a quiet and productive atmosphere even in busy industrial zones.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Custom Interior Layouts</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> T3 Tropical Rated AC</li>
                            </ul>
                        </div>
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Premium Flooring</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Rapid Site Setup</li>
                            </ul>
                        </div>
                    </div>

                    <a href="/contact" class="btn-bc btn-bc-yellow mt-4">Request a Quote <i class="bi bi-arrow-right ms-2"></i></a>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="position-relative">
                        <img src="/Uploads/WhatsApp Image 2026-04-22 at 3.41.42 PM.jpeg" class="img-fluid shadow-lg" alt="Portable Office Cabin" style="border-radius: 20px;">
                        <div class="bg-primary-yellow position-absolute p-4 d-none d-md-block" style="bottom: -30px; right: -30px; border-radius: 15px; max-width: 250px;">
                            <h5 class="fw-bold mb-0 text-dark">Ready for Immediate Use</h5>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Technical Specifications -->
            <div class="row mt-5 pt-5" data-aos="fade-up">
                <div class="col-12">
                    <h3 class="fw-bold mb-4">Technical Specifications</h3>
                    <div class="table-responsive">
                        <table class="table table-bordered custom-table">
                            <thead class="bg-dark text-white">
                                <tr>
                                    <th>Feature</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Chassis</strong></td>
                                    <td>ISMC Reinforced Structural Steel</td>
                                </tr>
                                <tr>
                                    <td><strong>Wall Panels</strong></td>
                                    <td>50mm/100mm EPS or Rockwool Sandwich Panels</td>
                                </tr>
                                <tr>
                                    <td><strong>Insulation</strong></td>
                                    <td>High-density Fire Resistant Materials</td>
                                </tr>
                                <tr>
                                    <td><strong>Flooring</strong></td>
                                    <td>18mm Cement Board with Premium Vinyl Finish</td>
                                </tr>
                                <tr>
                                    <td><strong>Electrical</strong></td>
                                    <td>Concealed wiring with DB Box & LED Lighting</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

<style>
    .section-label { font-size: 0.8rem; font-weight: 700; color: #ffcc00; text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 10px; }
    .section-title { font-size: 2.5rem; font-weight: 800; color: #111; line-height: 1.2; }
    .btn-bc { display: inline-flex; align-items: center; padding: 15px 35px; font-weight: 700; border-radius: 5px; transition: all 0.3s; text-decoration: none; text-transform: uppercase; font-size: 0.9rem; }
    .btn-bc-yellow { background: #ffcc00; color: #111; }
    .btn-bc-yellow:hover { background: #111; color: #ffcc00; }
    .custom-table { border-radius: 10px; overflow: hidden; }
</style>
