@{
    ViewBag.Title = "Container Offices Qatar | Modern Shipping Container Conversions";
    ViewBag.description = "Bespoke container offices and shipping container conversions in Qatar. High-durability, architecturally designed, and ready for rapid deployment in Doha.";
    ViewBag.keywords = "container office qatar, shipping container conversion doha, modular container office, bespoke container qatar";
}

<main id="main" class="product-detail-page">

    <!-- Hero Section -->
    <section class="page-hero" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/Uploads/Products/cabin-2.jpg') center/cover no-repeat; padding: 120px 0 80px;">
        <div class="container text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold text-white mb-3">Container Offices</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center">
                    <li class="breadcrumb-item"><a href="/index" class="text-warning">Home</a></li>
                    <li class="breadcrumb-item"><a href="/portable-cabin-fabrication" class="text-warning">Fabrication</a></li>
                    <li class="breadcrumb-item active text-white" aria-current="page">Container Offices</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Content Section -->
    <section class="py-5 bg-white">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <span class="section-label">Architectural Innovation</span>
                    <h2 class="section-title">Modern Shipping Container Conversions</h2>
                    <p class="lead text-muted mt-4">We transform standard 20ft and 40ft shipping containers into architecturally stunning and highly functional office spaces.</p>
                    <p class="text-muted">Featuring modern industrial aesthetics, high-performance insulation, and premium interior finishes, our container offices are ideal for luxury site offices and marketing suites.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> 20ft & 40ft Options</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Industrial Chic Design</li>
                            </ul>
                        </div>
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Marine-Grade Steel</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Premium Glazing</li>
                            </ul>
                        </div>
                    </div>

                    <a href="/contact" class="btn-bc btn-bc-yellow mt-4">Request Bespoke Design <i class="bi bi-arrow-right ms-2"></i></a>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="position-relative text-center">
                        <img src="/Uploads/WhatsApp Image 2026-04-22 at 3.41.45 PM.jpeg" class="img-fluid shadow-lg" alt="Container Office Conversion" style="border-radius: 20px;">
                        <div class="bg-primary-yellow position-absolute p-4 d-none d-md-block" style="bottom: -30px; right: -30px; border-radius: 15px; max-width: 250px;">
                            <h5 class="fw-bold mb-0 text-dark">Modern Industrial Style</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

<style>
    .section-label { font-size: 0.8rem; font-weight: 700; color: #ffcc00; text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 10px; }
    .section-title { font-size: 2.5rem; font-weight: 800; color: #111; line-height: 1.2; }
    .btn-bc { display: inline-flex; align-items: center; padding: 15px 35px; font-weight: 700; border-radius: 5px; transition: all 0.3s; text-decoration: none; text-transform: uppercase; font-size: 0.9rem; }
    .btn-bc-yellow { background: #ffcc00; color: #111; }
    .btn-bc-yellow:hover { background: #111; color: #ffcc00; }
</style>
