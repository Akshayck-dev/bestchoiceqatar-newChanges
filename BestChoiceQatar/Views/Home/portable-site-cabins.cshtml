@{
    ViewBag.Title = "Portable Site Cabins Qatar | Rugged Workforce Solutions";
    ViewBag.description = "Durable portable site cabins for workforce accommodation and operational support in Qatar. Engineered for harsh industrial environments and rapid deployment.";
    ViewBag.keywords = "portable site cabins qatar, workforce accommodation doha, site units qatar, industrial cabins";
}

<main id="main" class="product-detail-page">

    <!-- Hero Section -->
    <section class="page-hero" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/Uploads/Products/cabin-2.jpg') center/cover no-repeat; padding: 120px 0 80px;">
        <div class="container text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold text-white mb-3">Portable Site Cabins</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center">
                    <li class="breadcrumb-item"><a href="/index" class="text-warning">Home</a></li>
                    <li class="breadcrumb-item"><a href="/portable-cabin-fabrication" class="text-warning">Fabrication</a></li>
                    <li class="breadcrumb-item active text-white" aria-current="page">Site Cabins</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Content Section -->
    <section class="py-5 bg-white">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6 order-lg-2" data-aos="fade-left">
                    <span class="section-label">Industrial Grade</span>
                    <h2 class="section-title">Rugged Site Units for Qatar Projects</h2>
                    <p class="lead text-muted mt-4">Our portable site cabins are designed to withstand the toughest industrial conditions, providing reliable support for your workforce.</p>
                    <p class="text-muted">Built for repeated relocation and extreme weather resistance, these units are the preferred choice for major infrastructure projects in Mesaieed and Ras Laffan.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Heavy Duty Chassis</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Weatherproof Seals</li>
                            </ul>
                        </div>
                        <div class="col-md-6 mb-3">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Easy Clean Interiors</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Fast Relocation</li>
                            </ul>
                        </div>
                    </div>

                    <a href="/contact" class="btn-bc btn-bc-yellow mt-4">Get Site Pricing <i class="bi bi-arrow-right ms-2"></i></a>
                </div>
                <div class="col-lg-6 order-lg-1" data-aos="fade-right">
                    <div class="position-relative">
                        <img src="/Uploads/WhatsApp Image 2026-04-22 at 3.41.44 PM (1).jpeg" class="img-fluid shadow-lg" alt="Portable Site Cabin" style="border-radius: 20px;">
                        <div class="bg-primary-yellow position-absolute p-4 d-none d-md-block" style="top: -30px; left: -30px; border-radius: 15px; max-width: 250px;">
                            <h5 class="fw-bold mb-0 text-dark">Built for Industrial Use</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

<style>
    .section-label { font-size: 0.8rem; font-weight: 700; color: #ffcc00; text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 10px; }
    .section-title { font-size: 2.5rem; font-weight: 800; color: #111; line-height: 1.2; }
    .btn-bc { display: inline-flex; align-items: center; padding: 15px 35px; font-weight: 700; border-radius: 5px; transition: all 0.3s; text-decoration: none; text-transform: uppercase; font-size: 0.9rem; }
    .btn-bc-yellow { background: #ffcc00; color: #111; }
    .btn-bc-yellow:hover { background: #111; color: #ffcc00; }
</style>
