@{
    ViewBag.Title = product.Title + " | Bestchoice Contracting Qatar";
    ViewBag.description = product.MetaDescription;
    ViewBag.keywords = product.MetaKeywords;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ======= Premium UI Styles ======= -->
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap');

    :root {
        --primary-yellow: #ffcc00;
        --dark-bg: #111111;
        --light-bg: #ffffff;
        --transition-smooth: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    body {
        font-family: var(--font-body);
        font-size: var(--fs-base);
        background-color: var(--light-bg);
    }

    /* Hero Section */
    .premium-hero {
        position: relative;
        height: 70vh;
        min-height: 500px;
        background: url('@product.MainImage') center/cover no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 100%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 1100px;
    }

    .hero-title {
        font-weight: 900;
        font-size: var(--fs-h1);
        line-height: 1.05;
        text-transform: uppercase;
        color: #fff;
        margin-bottom: 2rem;
        letter-spacing: var(--ls-tight);
    }

    .hero-subtitle {
        font-size: var(--fs-md);
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 3rem;
        border-left: 4px solid var(--primary-yellow);
        padding-left: 20px;
        line-height: var(--lh-body);
    }

    .section-label {
        color: var(--primary-yellow);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 2px;
        font-size: 0.9rem;
        display: block;
        margin-bottom: 15px;
    }

    .bc-breadcrumb { margin-bottom: 20px; }
    .bc-breadcrumb a { color: var(--primary-yellow); text-decoration: none; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
    .bc-breadcrumb span { color: #888; margin: 0 10px; font-size: 0.8rem; }

    /* Main Content */
    .product-main { padding: 100px 0; }
    
    .content-card {
        background: #fff;
        padding: 0;
    }

    .main-description {
        font-size: var(--fs-md);
        line-height: var(--lh-body);
        color: #111;
        margin-bottom: 40px;
        font-weight: 600;
    }

    .detailed-text {
        color: #444;
        line-height: var(--lh-body);
        font-size: var(--fs-base);
        margin-bottom: 60px;
    }

    /* Features Grid */
    .feature-item {
        margin-bottom: 30px;
        padding: 25px;
        background: #fdfdfd;
        border-bottom: 3px solid #eee;
        transition: var(--transition-smooth);
        height: 100%;
    }

    .feature-item:hover {
        border-bottom-color: var(--primary-yellow);
        transform: translateY(-5px);
        background: #fff;
        box-shadow: 0 15px 30px rgba(0,0,0,0.05);
    }

    .feature-item i {
        font-size: 1.5rem;
        color: var(--primary-yellow);
        margin-bottom: 15px;
        display: block;
    }

    .feature-item p {
        margin-bottom: 0;
        font-weight: 600;
        font-size: var(--fs-base);
        color: #333;
    }

    /* Specifications Table */
    .spec-table-container {
        margin-top: 80px;
        background: #111;
        padding: 50px;
        color: #fff;
    }

    .spec-table {
        width: 100%;
        border-collapse: collapse;
    }

    .spec-table th, .spec-table td {
        padding: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        text-align: left;
    }

    .spec-table th {
        width: 35%;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        color: var(--primary-yellow);
    }

    .spec-table td {
        color: #ccc;
        font-size: var(--fs-base);
    }

    /* Sidebar Navigation */
    .sidebar-nav {
        position: sticky;
        top: 100px;
    }

    .nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        border: 1px solid #eee;
    }

    .nav-header {
        background: #000;
        color: #fff;
        padding: 20px 25px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.9rem;
    }

    .nav-list li a {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 25px;
        border-bottom: 1px solid #eee;
        color: #444;
        text-decoration: none;
        font-weight: 700;
        transition: var(--transition-smooth);
        font-size: 0.95rem;
    }

    .nav-list li a:hover, .nav-list li a.active {
        background: var(--primary-yellow);
        color: #000;
        padding-left: 35px;
    }

    .cta-sidebar {
        background: #f8f8f8;
        padding: 40px;
        margin-top: 40px;
        border-left: 5px solid var(--primary-yellow);
    }

    .cta-sidebar h4 { font-weight: 900; text-transform: uppercase; margin-bottom: 20px; font-size: 1.2rem; }
    .cta-sidebar p { color: #666; font-size: 0.95rem; margin-bottom: 30px; }

    .btn-premium {
        display: block;
        width: 100%;
        text-align: center;
        padding: 15px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        transition: var(--transition-smooth);
        margin-bottom: 15px;
    }

    .btn-yellow { background: var(--primary-yellow); color: #000; }
    .btn-yellow:hover { background: #000; color: #fff; }

    .btn-dark-outline { border: 2px solid #000; color: #000; }
    .btn-dark-outline:hover { background: #000; color: #fff; }

    /* Gallery Section */
    .gallery-swiper {
        padding: 50px 0;
    }

    .swiper-slide {
        height: 350px;
        overflow: hidden;
    }

    .swiper-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition-smooth);
    }

    .swiper-slide:hover img { transform: scale(1.1); }


    /* --- MOBILE RESPONSIVENESS --- */
    @@media (max-width: 991.98px) {
        .premium-hero { height: 60vh; }
        .product-main { padding: 60px 0; }
        .spec-table-container { padding: 30px; }
        .sidebar-nav { margin-top: 60px; position: static; }
    }

    @@media (max-width: 767.98px) {
        .hero-title { font-size: 2.2rem; }
        .hero-subtitle { border-left: none; border-top: 4px solid var(--primary-yellow); padding-left: 0; padding-top: 15px; }
        .spec-table th { width: 100%; display: block; padding-bottom: 5px; }
        .spec-table td { display: block; padding-top: 0; padding-bottom: 15px; }
    }
</style>


<main id="main">
    <!-- Hero Section -->
    <section class="premium-hero">
        <div class="hero-overlay"></div>
        <div class="container position-relative">
            <div class="hero-content" data-aos="fade-up">
                <nav class="bc-breadcrumb">
                    <a href="/index">Home</a>
                    <span>/</span>
                    <a href="/portable-cabin-fabrication">Fabrication</a>
                    <span>/</span>
                    <span style="color:rgba(255,255,255,0.5)">@product.Title</span>
                </nav>
                <span class="section-label">@product.SectionLabel</span>
                <h1 class="hero-title">@product.Title</h1>
                <p class="hero-subtitle">@product.Subtitle</p>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="product-main">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-8">
                    <div class="content-card" data-aos="fade-up">
                        <h2 class="section-label mb-3">Overview</h2>
                        <p class="main-description">@Html.Raw(product.Description)</p>
                        <p class="detailed-text">@product.DetailedContent</p>

                        <div class="row g-4">
                            <div class="col-12"><h2 class="section-label mb-4">Technical Highlights</h2></div>
                            @foreach (var feature in product.Features)
                            {
                                <div class="col-md-6" data-aos="fade-up">
                                    <div class="feature-item">
                                        <i class="bi bi-shield-check"></i>
                                        <p>@feature</p>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="spec-table-container" data-aos="fade-up">
                            <h2 class="section-label mb-4" style="color: #fff;">Standard Specifications</h2>
                            <table class="spec-table">
                                <tbody>
                                    @foreach (var spec in product.Specifications)
                                    {
                                        <tr>
                                            <th>@spec.Key</th>
                                            <td>@spec.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <aside class="sidebar-nav" data-aos="fade-left">
                        <div class="nav-header">Cabin Categories</div>
                        <ul class="nav-list">
                            @foreach (var item in allProducts)
                            {
                                <li>
                                    <a href="/product/@item.Slug" class="@(item.Slug == product.Slug ? "active" : "")">
                                        @item.Title <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>

                        <div class="cta-sidebar">
                            <h4>Ready to Start?</h4>
                            <p>Get a customized quote for your modular project including technical drawings and on-site delivery costs.</p>
                            <a href="/contact" class="btn-premium btn-yellow">Request Quote</a>
                            <a href="tel:@settings.Mobile1" class="btn-premium btn-dark-outline">Call Specialist</a>
                        </div>

                        <div class="mt-4 p-4 border text-center">
                            <h5 class="fw-bold mb-3">Download Brochure</h5>
                            <a href="~/Content/assets/Brochure/Brochure.html.pdf" target="_blank" class="text-dark text-decoration-none fw-bold">
                                <i class="bi bi-file-earmark-pdf-fill fs-3 d-block mb-2 text-danger"></i>
                                Get Full PDF Catalog
                            </a>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Section -->
    <section class="bg-light py-5">
        <div class="container">
            <div class="section-header text-center mb-5" data-aos="fade-up">
                <span class="section-label">Gallery</span>
                <h2 class="fw-black text-uppercase" style="font-size: 2.5rem; letter-spacing: -1px;">Project Showcase</h2>
            </div>
            <div class="swiper gallery-swiper" data-aos="fade-up">
                <div class="swiper-wrapper">
                    @foreach (var img in product.GalleryImages)
                    {
                        <div class="swiper-slide">
                            <a href="@img" class="glightbox">
                                <img src="@img" alt="BestChoice Qatar Cabin">
                            </a>
                        </div>
                    }
                </div>
                <div class="swiper-pagination mt-4"></div>
            </div>
        </div>
    </section>

    <!-- SEO CONTENT SECTION -->
    <section class="dark-section" style="background-color: var(--dark-bg); color: #fff; padding: 100px 0;">
        <div class="container" data-aos="fade-up">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6">
                    <span class="section-label">Expertise in Qatar</span>
                    <h2 class="hero-title" style="font-size: 2.5rem; text-transform: none;">Leading Modular Fabrication in Doha</h2>
                    <p style="color: #888; line-height: 1.8; font-size: 1.1rem;">
                        BestChoice Contracting is a premier provider of <strong>portable cabins and modular buildings in Qatar</strong>. With over 15 years of experience in the Doha market, we have mastered the art of fabricating structures that specifically address the environmental and regulatory challenges of the region.
                    </p>
                    <p style="color: #888; line-height: 1.8;">
                        Our solutions for <a href="/product/labor-camps-accommodation" style="color: var(--primary-yellow);">labor accommodation</a>, <a href="/product/porta-cabin-offices" style="color: var(--primary-yellow);">site offices</a>, and <a href="/product/container-office-cabins" style="color: var(--primary-yellow);">container conversions</a> are utilized by Qatar's largest infrastructure and oil & gas projects. We pride ourselves on engineering excellence, rapid deployment, and unmatched durability.
                    </p>
                </div>
                <div class="col-lg-6">
                    <div class="row g-4">
                        <div class="col-6">
                            <div class="p-4 border border-secondary h-100">
                                <h3 class="fw-bold fs-1 text-white">10+</h3>
                                <p class="text-warning text-uppercase fw-bold small">Years Expertise</p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-4 border border-secondary h-100">
                                <h3 class="fw-bold fs-1 text-white">500+</h3>
                                <p class="text-warning text-uppercase fw-bold small">Units Delivered</p>
                            </div>
