@{
    var slugObj = ViewContext.RouteData.Values["slug"];
    var slug = (slugObj != null ? slugObj.ToString() : null) ?? Request.QueryString["slug"];
    var product = GetProductData().FirstOrDefault(p => p.Slug == (slug ?? "").ToLower());
    
    BestChoiceQatar.Models.BestChoiceQatarEntities db = new BestChoiceQatar.Models.BestChoiceQatarEntities();
    var settings = db.Settings.FirstOrDefault();
    var allProducts = GetProductData();

    if (product == null) {
        Response.Redirect("/index");
        return;
    }
}

