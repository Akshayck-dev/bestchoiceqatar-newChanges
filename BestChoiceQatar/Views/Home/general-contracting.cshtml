
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Experienced General Contracting Services | Bestchoice for Civil, Electrical, and More";
    ViewBag.description = "Experienced General Contracting Services. We offer solutions for Civil, Electrical, Mechanical, Carpentry, and more. Quality and cost-effective solutions.";
    ViewBag.keywords = "general contracting services, civil contracting, electrical services, mechanical solutions, carpentry contractors, maintenance and repairs";
    BestChoiceQatar.Models.BestChoiceQatarEntities db = new BestChoiceQatar.Models.BestChoiceQatarEntities();
    var settings = db.Settings.FirstOrDefault();
    var _product = (from b in db.Galleries
                    where b.IsDataActive && b.Category == "General Contracting"
                    select new
                    {
                        b.ID,
                        b.Title,
                        b.Description,
                        b.Image,
                        b.ChildImages
                    }).FirstOrDefault();
}



<!-- ======= Breadcrumbs ======= -->
<div class="breadcrumbs d-flex align-items-center" style="background-image: url('../content/assets/img/header/General\ Contracting.jpg');">
    <div class="container position-relative d-flex flex-column align-items-center">

        <h2>General Contracting</h2>
        <ol>
            <li><a href="/index">Home</a></li>
            <li>General Contracting</li>
        </ol>

    </div>
</div><!-- End Breadcrumbs -->
<!-- ======= Products ======= -->
<section id="Products" class="Products">
    <div class="container" data-aos="fade-up">

        <div class="row">
            <div class="col-lg-6 order-1 order-lg-2" data-aos="fade-left" data-aos-delay="100">
                <img src="~/Uploads/Products/@_product.Image" class="img-fluid" alt="Experienced General Contracting Services">
            </div>
            <div class="col-lg-6 pt-4 pt-lg-0 order-2 order-lg-1 content" data-aos="fade-right" data-aos-delay="100">
                <h1>@_product.Title</h1>
                @Html.Raw(_product.Description)
            </div>
        </div>
    </div>
</section><!-- End Products Section -->


<main id="main">
    <!-- ======= Recent Photos Section ======= -->
    <section id="recent-photos" class="recent-photos">
        <div class="container">

            <div class="section-title">
                <h2>Photos</h2>
                <p>General Contracting</p>
            </div>

            <div class="recent-photos-slider swiper">
                <div class="swiper-wrapper align-items-center">
                    @if (!string.IsNullOrEmpty(_product.ChildImages))
                    {
                        List<string> _files = _product.ChildImages.Split('|').ToList();
                        foreach (var _fileName in _files.Where(f => !string.IsNullOrEmpty(f)).ToList())
                        {
                            <div class="swiper-slide"><a href="~/Uploads/Products/@_fileName" class="glightbox"><img src="~/Uploads/Products/@_fileName" class="img-fluid" alt="Experienced General Contracting Services"></a></div>
                        }
                    }

                    @*<div class="swiper-slide"><a href="~/content/assets/img/Products/General Contracting/General Contracting-1.jpg" class="glightbox"><img src="~/content/assets/img/Products/General Contracting/General Contracting-1.jpg" class="img-fluid" alt="Experienced General Contracting Services"></a></div>
                    <div class="swiper-slide"><a href="~/content/assets/img/Products/General Contracting/General Contracting-2.jpg" class="glightbox"><img src="~/content/assets/img/Products/General Contracting/General Contracting-2.jpg" class="img-fluid" alt="Experienced General Contracting Services"></a></div>
                    <div class="swiper-slide"><a href="~/content/assets/img/Products/General Contracting/General Contracting-3.jpg" class="glightbox"><img src="~/content/assets/img/Products/General Contracting/General Contracting-3.jpg" class="img-fluid" alt="Experienced General Contracting Services"></a></div>
                    <div class="swiper-slide"><a href="~/content/assets/img/Products/General Contracting/General Contracting-4.jpg" class="glightbox"><img src="~/content/assets/img/Products/General Contracting/General Contracting-4.jpg" class="img-fluid" alt="Experienced General Contracting Services"></a></div>
                    <div class="swiper-slide"><a href="~/content/assets/img/Products/General Contracting/General Contracting-5.JPG" class="glightbox"><img src="~/content/assets/img/Products/General Contracting/General Contracting-5.jpg" class="img-fluid" alt="Experienced General Contracting Services"></a></div>
                    <div class="swiper-slide"><a href="~/content/assets/img/Products/General Contracting/General Contracting-6.JPG" class="glightbox"><img src="~/content/assets/img/Products/General Contracting/General Contracting-6.jpg" class="img-fluid" alt="Experienced General Contracting Services"></a></div>*@

                </div>
                <div class="swiper-pagination"></div>
            </div>

        </div>
    </section><!-- End Recent Photos Section -->

</main><!-- End #main -->
