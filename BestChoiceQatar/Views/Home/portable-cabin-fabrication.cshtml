    </section>

    <!-- Features Section -->
    <section class="bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-5" data-aos="fade-right">
                    <span class="section-label">Superior Standards</span>
                    <h2 class="section-title mb-4">Engineering That Speaks Quality</h2>
                    <p class="lead text-muted mb-5">We utilize advanced fabrication techniques and premium materials to ensure every cabin meets international safety and comfort standards.</p>
                    <img src="https://images.unsplash.com/photo-1541976590-713941681591?q=80&w=1000&auto=format&fit=crop" class="img-fluid rounded-0 shadow-lg" alt="Industrial">
                </div>
                <div class="col-lg-6 offset-lg-1">
                    <div class="row">
                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="100">
                            <div class="feature-item">
                                <i class="bi bi-shield-lock"></i>
                                <h5>Ultra Durable</h5>
                                <p>Double-welded steel frames designed for high-stress industrial use.</p>
                            </div>
                        </div>
                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="200">
                            <div class="feature-item">
                                <i class="bi bi-thermometer-half"></i>
                                <h5>Climate Controlled</h5>
                                <p>Engineered insulation layers to maintain 22°C even in 50°C external heat.</p>
                            </div>
                        </div>
                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="300">
                            <div class="feature-item">
                                <i class="bi bi-tools"></i>
                                <h5>Plug & Play</h5>
                                <p>Pre-installed electrical, plumbing, and communication systems.</p>
                            </div>
                        </div>
                        <div class="col-sm-6" data-aos="fade-up" data-aos-delay="400">
                            <div class="feature-item">
                                <i class="bi bi-geo-fill"></i>
                                <h5>Relocatable</h5>
                                <p>Optimized for repeated lifting and transport across multiple sites.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Section -->
    <section class="gallery-section">
        <div class="container">
            <div class="section-header text-center" data-aos="fade-up">
                <span class="section-label">Visual Journal</span>
                <h2 class="section-title">Fabrication Excellence</h2>
            </div>
            <div class="swiper gallery-swiper" data-aos="fade-up">
                <div class="swiper-wrapper">
                    @{
                        List<string> allImages = new List<string>();
                        for (int j = 1; j <= 13; j++) {
                            string ext = (j == 5 || j == 6) ? "JPG" : "jpg";
                            allImages.Add(Url.Content("~/Content/assets/img/Products/cabin/cabin-" + j + "." + ext));
                        }
                        if (!string.IsNullOrEmpty(_product.ChildImages)) {
                            var dbFiles = _product.ChildImages.Split('|').Where(f => !string.IsNullOrEmpty(f) && !f.Contains("cabin-"));
                            foreach (var file in dbFiles) {
                                allImages.Add(Url.Content("~/Uploads/Products/" + file));
                            }
                        }
                        foreach (var imgUrl in allImages.Take(10))
                        {
                            <div class="swiper-slide">
                                <a href="@imgUrl" class="glightbox">
                                    <img src="@imgUrl" alt="Portable Cabin Fabrication">
                                </a>
                            </div>
                        }
                    }
                </div>
                <div class="swiper-pagination"></div>
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
            </div>
        </div>
    </section>

    <!-- Process Section -->
    <section class="dark-section">
        <div class="container">
            <div class="section-header text-center" data-aos="fade-up">
                <span class="section-label">Workflow</span>
                <h2 class="section-title">The Path to Delivery</h2>
            </div>
            <div class="row g-5">
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="100">
                    <div class="process-step">
                        <span class="step-number">01</span>
                        <div class="process-content">
                            <h5>Consultation</h5>
                            <p>Defining space requirements and technical specifications for your site.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="process-step">
                        <span class="step-number">02</span>
                        <div class="process-content">
                            <h5>Bespoke Design</h5>
                            <p>Architectural drafting and material selection tailored to your needs.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="300">
                    <div class="process-step">
                        <span class="step-number">03</span>
                        <div class="process-content">
                            <h5>Precision Build</h5>
                            <p>Controlled fabrication within our facility with rigorous quality testing.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="400">
                    <div class="process-step">
                        <span class="step-number">04</span>
                        <div class="process-content">
                            <h5>Installation</h5>
                            <p>Seamless delivery and on-site integration by our specialized crew.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SEO CONTENT SECTION -->
