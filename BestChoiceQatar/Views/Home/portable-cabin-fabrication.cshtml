                    <p>Market Pricing</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Cabin Types -->
    <section id="types">
        <div class="container">
            <div class="section-header text-center" data-aos="fade-up">
                <span class="section-label">Product Portfolio</span>
                <h2 class="section-title">Specialized Fabrication</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                    <div class="cabin-card">
                        <div class="icon-box"><i class="bi bi-briefcase"></i></div>
                        <h4>Site Office</h4>
                        <p>Optimized workspace environments for construction and project management teams.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="cabin-card">
                        <div class="icon-box"><i class="bi bi-people"></i></div>
                        <h4>Accommodation</h4>
                        <p>High-comfort living quarters with advanced thermal insulation and interior finish.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                    <div class="cabin-card">
                        <div class="icon-box"><i class="bi bi-water"></i></div>
                        <h4>Toilet Cabin</h4>
                        <p>Premium sanitary solutions built for hygiene and long-term maintenance ease.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
