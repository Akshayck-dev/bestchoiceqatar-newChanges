@{
    var slug = Request.QueryString["slug"];
    if (!string.IsNullOrEmpty(slug))
    {
        @Html.Partial("ProductDetails")
        return;
    }
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Explore High-Quality Portable Cabin Fabrication Services";
    ViewBag.description = "Discover custom portable cabins at bestchoice contracting: quality, durability, and tailored solutions. Contact us today.";
    ViewBag.keywords = "portable cabin fabrication services, custom portable cabins, cabin fabrication in qatar, steel cabin fabrication";

    int i = 1;
    BestChoiceQatar.Models.BestChoiceQatarEntities db = new BestChoiceQatar.Models.BestChoiceQatarEntities();
    var _product = (from b in db.Galleries
                    where b.IsDataActive && b.Category == "Portable Cabin Fabrication"
                    select new
                    {
                        b.ID,
                        b.Title,
                        b.Description,
                        b.Image,
                        b.ChildImages
                    }).FirstOrDefault();
    var settings = db.Settings.FirstOrDefault();
}


