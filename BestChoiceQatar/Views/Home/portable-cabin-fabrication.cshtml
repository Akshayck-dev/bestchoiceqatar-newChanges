                <p class="hero-subtitle">Engineering premium modular spaces that redefine versatility and durability in Qatar's landscape.</p>
                <div class="hero-actions">
                    <a href="#final-cta" class="btn btn-premium btn-yellow">Get a Quote</a>
                    <a href="tel:@settings.Mobile1" class="btn btn-premium btn-outline-white">Call Specialist</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Trust Strip -->
