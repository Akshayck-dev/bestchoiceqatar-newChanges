<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&display=swap');

    :root {
        --primary-yellow: #ffcc00;
        --dark-bg: #111111;
        --light-bg: #ffffff;
        --transition-smooth: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    body {
        font-family: var(--font-body);
        font-size: var(--fs-base);
        line-height: var(--lh-body);
        background-color: var(--light-bg);
        color: var(--dark-bg);
    }

    /* Hero Section */
    .premium-hero {
        position: relative;
        height: 90vh;
        min-height: 600px;
        background: url('https://images.unsplash.com/photo-1503387762-592dea58ef23?q=80&w=2000&auto=format&fit=crop') center/cover no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 100%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 900px;
    }

    .hero-title {
        font-weight: 800;
        font-size: var(--fs-h1);
        line-height: 1.15;
        text-transform: uppercase;
        color: #fff;
        margin-bottom: 2rem;
        letter-spacing: var(--ls-tight);
    }

    .hero-subtitle {
        font-size: var(--fs-md);
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 3rem;
        border-left: 4px solid var(--primary-yellow);
        padding-left: 20px;
        line-height: var(--lh-body);
    }

    .btn-premium {
        padding: 18px 40px;
        font-weight: 700;
        text-transform: uppercase;
        border-radius: 0;
        transition: var(--transition-smooth);
        letter-spacing: 1px;
    }

    .btn-yellow {
        background-color: var(--primary-yellow);
        color: #000;
        border: 2px solid var(--primary-yellow);
    }

    .btn-yellow:hover {
        background-color: transparent;
        color: var(--primary-yellow);
    }

    .btn-outline-white {
        background-color: transparent;
        color: #fff;
        border: 2px solid rgba(255, 255, 255, 0.3);
        margin-left: 15px;
    }

    .btn-outline-white:hover {
        border-color: #fff;
        background-color: #fff;
        color: #000;
    }

    /* Trust Strip */
    .trust-strip {
        background: #000;
        padding: 40px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .trust-item h3 {
        color: var(--primary-yellow);
        font-weight: 800;
        font-size: var(--fs-xl);
        margin-bottom: 0;
    }

    .trust-item p {
        color: #888;
        text-transform: uppercase;
        font-size: var(--fs-xs);
        font-weight: 700;
        letter-spacing: 0.1em;
    }

    body { overflow-x: hidden; width: 100%; position: relative; }
    html { overflow-x: hidden; width: 100%; }
    
    /* Global Image Safety */
    img { max-width: 100% !important; height: auto !important; }

    /* Section Spacing */
    section {
        padding: 120px 0;
        width: 100%;
        overflow: hidden;
    }

    .section-header {
        margin-bottom: 80px;
    }

    .section-label {
        color: var(--primary-yellow);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 2px;
        font-size: 0.9rem;
        display: block;
        margin-bottom: 15px;
    }

    .section-title {
        font-weight: 800;
        font-size: var(--fs-h2);
        text-transform: uppercase;
        letter-spacing: -0.01em;
    }

    /* Cabin Types */
    .cabin-card {
        background: #fff;
        border: 1px solid #eee;
        padding: 40px;
        height: 100%;
        transition: var(--transition-smooth);
        position: relative;
        overflow: hidden;
    }

    .cabin-card:hover {
        transform: translateY(-15px);
        border-color: var(--primary-yellow);
        box-shadow: 0 30px 60px rgba(0,0,0,0.05);
    }

    .cabin-card .icon-box {
        width: 60px;
        height: 60px;
        background: #f8f8f8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: var(--dark-bg);
        margin-bottom: 30px;
        transition: var(--transition-smooth);
    }

    .cabin-card:hover .icon-box {
        background: var(--primary-yellow);
        color: #000;
    }

    .cabin-card h4 {
        font-weight: 700;
        margin-bottom: 15px;
        text-transform: uppercase;
    }

    /* Features Grid */
    .feature-item {
        margin-bottom: 40px;
        padding: 30px;
        border-left: 2px solid #eee;
        transition: var(--transition-smooth);
    }

    .feature-item:hover {
        border-left-color: var(--primary-yellow);
        background: #fdfdfd;
    }

    .feature-item i {
        font-size: 2.5rem;
        color: var(--primary-yellow);
        margin-bottom: 20px;
        display: block;
    }

    /* Swiper Gallery Carousel */
    .gallery-swiper {
        padding: 40px 0 80px;
        overflow: hidden;
    }

    .swiper-slide {
        height: 400px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        transition: var(--transition-smooth);
    }

    .swiper-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .swiper-slide:hover img {
        transform: scale(1.1);
    }

    .swiper-button-next, .swiper-button-prev {
        color: var(--primary-yellow);
        background: rgba(0,0,0,0.8);
        width: 50px;
        height: 50px;
        border-radius: 0;
    }

    .swiper-button-next:after, .swiper-button-prev:after {
        font-size: 1.2rem;
        font-weight: 900;
    }

    .swiper-pagination-bullet {
        background: #000;
        opacity: 0.2;
        width: 12px;
        height: 12px;
        border-radius: 0;
    }

    .swiper-pagination-bullet-active {
        background: var(--primary-yellow);
        opacity: 1;
        width: 30px;
    }

    /* Animations */
    [data-aos] {
        transition-duration: 800ms !important;
    }

    /* Process Section */
    .dark-section {
        background-color: var(--dark-bg);
        color: #fff;
    }

    .process-step {
        position: relative;
        padding-top: 50px;
    }

    .step-number {
        font-size: 6rem;
        font-weight: 900;
        color: rgba(255, 204, 0, 0.08);
        position: absolute;
        top: 0;
        left: 0;
        line-height: 1;
    }

    .process-content {
        position: relative;
        z-index: 1;
    }

    .process-content h5 {
        color: var(--primary-yellow);
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 15px;
        font-size: 1.2rem;
    }

    /* Final CTA */
    .final-cta {
        background: var(--primary-yellow);
        text-align: center;
        padding: 150px 0;
    }

    .final-cta h2 {
        font-weight: 800;
        font-size: var(--fs-h1);
        text-transform: uppercase;
        margin-bottom: 50px;
        color: #000;
        line-height: 1.1;
        letter-spacing: -0.01em;
    }

    /* --- COMPREHENSIVE MOBILE RESPONSIVENESS --- */
    @@media (max-width: 991.98px) {
        section { padding: 80px 0; }
        .hero-title { font-size: 3.5rem; }
        .final-cta { padding: 80px 0; }
        .final-cta h2 { font-size: 3rem; }
    }

    @@media (max-width: 767.98px) {
        section { padding: 50px 0; }
        
        /* Hero Refinement */
        .premium-hero { height: auto; min-height: 550px; padding: 120px 0 60px; text-align: center; }
        .hero-title { font-size: 2.8rem; line-height: 1.1; margin-bottom: 1.5rem; letter-spacing: -1px; }
        .hero-subtitle { border-left: none; border-top: 4px solid var(--primary-yellow); padding-left: 0; padding-top: 15px; margin-bottom: 2.5rem; }
        
        /* Button Stacking */
        .btn-premium { width: 100%; margin-left: 0 !important; margin-bottom: 10px; }
        
        /* Trust Strip */
        .trust-strip { padding: 40px 20px; text-align: center; }
        .trust-item { margin-bottom: 30px; }
        .trust-item:last-child { margin-bottom: 0; }
        
        /* Content Spacing */
        .section-header { margin-bottom: 50px; text-align: center; }
        .feature-item { padding: 20px; border-left: none; border-top: 2px solid #eee; }
        .feature-item:hover { border-top-color: var(--primary-yellow); }
        
        /* Process Section */
        .process-step { padding-top: 30px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 30px; }
        .step-number { position: relative; font-size: 4rem; margin-bottom: 10px; display: block; width: 100%; }
        
        /* Modern CSS Carousel for Mobile Gallery */
        .gallery-grid {
            display: flex;
            flex-wrap: nowrap;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            gap: 15px;
            padding: 0 15px 30px;
            margin: 0 -15px;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .gallery-grid::-webkit-scrollbar { display: none; }
        .gallery-grid .gallery-item {
            flex: 0 0 85%;
            width: 85% !important;
            max-width: 85% !important;
            scroll-snap-align: center;
        }

        /* Final CTA */
        .final-cta h2 { font-size: 2rem; margin-bottom: 30px; }

        /* Hide conflicting legacy elements */
        .tagline, .my-tagline { display: none !important; }
    }
            width: auto;
        }
    }
</style>

<main id="main">
