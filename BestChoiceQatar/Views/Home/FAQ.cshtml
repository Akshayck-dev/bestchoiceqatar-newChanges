@{
    ViewBag.Title = "Frequently Asked Questions | Bestchoice Contracting Qatar";
    ViewBag.description = "Find answers to common questions about portable cabins, modular structures, shipping container conversions, and fabrication services in Qatar.";
    ViewBag.keywords = "faq bestchoice qatar, portable cabin questions, modular building qatar, fabrication faq";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-yellow: #ffcc00;
        --industrial-dark: #111111;
    }

    .faq-hero {
        background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('/Content/assets/img/header/about-header.jpg') center/cover;
        padding: 100px 0;
        text-align: center;
        color: #fff;
    }

    .faq-hero h1 {
        font-weight: 800;
        font-size: 3.5rem;
        text-transform: uppercase;
        letter-spacing: -1px;
        margin-bottom: 20px;
        color: #ffffff;
    }

    .faq-hero .breadcrumb-custom {
        display: flex;
        justify-content: center;
        gap: 10px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 2px;
    }

    .breadcrumb-custom a { color: var(--primary-yellow); text-decoration: none; }
    .breadcrumb-custom span { color: rgba(255,255,255,0.5); }

    .faq-container {
        padding: 100px 0;
        background-color: #f9f9f9;
    }

    .accordion-industrial .accordion-item {
        border: none;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .accordion-industrial .accordion-button {
        padding: 25px 30px;
        font-weight: 700;
        color: #111;
        background-color: #fff;
        border-left: 5px solid var(--primary-yellow);
        font-size: 1.1rem;
    }

    .accordion-industrial .accordion-button:not(.collapsed) {
        background-color: #fff;
        color: var(--industrial-dark);
        box-shadow: none;
    }

    .accordion-industrial .accordion-button:focus {
        box-shadow: none;
    }

    .accordion-industrial .accordion-body {
        padding: 30px;
        background-color: #fff;
        color: #555;
        line-height: 1.8;
        font-size: 1.05rem;
        border-top: 1px solid #eee;
    }

    .faq-sidebar {
        background-color: var(--industrial-dark);
        color: #fff;
        padding: 40px;
        border-radius: 0;
        position: sticky;
        top: 120px;
    }

    .faq-sidebar h3 {
        font-weight: 800;
        text-transform: uppercase;
        font-size: 1.5rem;
        margin-bottom: 25px;
        color: var(--primary-yellow);
    }

    .contact-item {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
    }

    .contact-item i {
        color: var(--primary-yellow);
        font-size: 1.5rem;
    }

    .contact-item div h5 {
        font-weight: 700;
        margin-bottom: 5px;
        font-size: 0.9rem;
        text-transform: uppercase;
        color: rgba(255,255,255,0.6);
    }

    .contact-item div p {
        margin: 0;
        font-weight: 600;
        font-size: 1.1rem;
    }

    .contact-item div a {
        color: #fff;
        text-decoration: none;
    }

    .contact-item div a:hover {
        color: var(--primary-yellow);
    }

    @@media (max-width: 767.98px) {
        .faq-hero h1 { font-size: 2.5rem; }
        .faq-sidebar { margin-top: 50px; }
    }
</style>

<main id="main">
    <!-- Hero -->
    <section class="faq-hero">
        <div class="container" data-aos="fade-up">
            <h1>Frequently Asked Questions</h1>
            <div class="breadcrumb-custom">
                <a href="/index">Home</a>
                <span>/</span>
                <span>FAQ</span>
            </div>
        </div>
    </section>

    <!-- FAQ Content -->
    <section class="faq-container">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-8">
                    <div class="accordion accordion-industrial" id="faqPageAccordion">
                        
                        <!-- Q1 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                    What types of structures does BESTCHOICE Contracting provide?
                                </button>
                            </h2>
                            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    We provide prefabricated cabins, modular structures, portable houses, used shipping container offices/homes, portable toilets, and other custom portable solutions tailored to industries such as construction, oil & gas, and infrastructure.
                                </div>
                            </div>
                        </div>

                        <!-- Q2 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                    Are your products suitable for Qatar's weather conditions?
                                </button>
                            </h2>
                            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Yes. All our products are built with weather-resistant materials to handle Qatar's heat, sand, and humidity. Our cabins and structures are designed for durability, safety, and comfort, even in harsh environments.
                                </div>
                            </div>
                        </div>

                        <!-- Q3 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                    Can I customize the design of my modular or portable unit?
                                </button>
                            </h2>
                            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Absolutely. We offer fully customizable layouts, finishes, features, and dimensions. Whether you need extra insulation, air conditioning, partitions, plumbing, or electrical work, our team can tailor your structure to meet your needs.
                                </div>
                            </div>
                        </div>

                        <!-- Q4 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                    Do you offer used shipping container offices and homes?
                                </button>
                            </h2>
                            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Yes, we offer refurbished shipping containers that can be converted into offices, houses, shops, or storage units. These are affordable, eco-friendly, and easily transportable — ideal for temporary or permanent use.
                                </div>
                            </div>
                        </div>

                        <!-- Q5 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                                    What types of clients or industries do you serve?
                                </button>
                            </h2>
                            <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    We serve a wide range of clients including construction companies, oil & gas operations, infrastructure developers, event organizers, government agencies, and private individuals needing residential or commercial space solutions.
                                </div>
                            </div>
                        </div>

                        <!-- Q6 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq6">
                                    Do you offer portable toilets and sanitation units?
                                </button>
                            </h2>
                            <div id="faq6" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Yes, we provide portable toilets that meet high hygiene standards. Options include basic units, VIP toilets, and those with hand-washing stations, urinals, or showers — perfect for job sites, events, and remote locations.
                                </div>
                            </div>
                        </div>

                        <!-- Q7 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq7">
                                    Are modular and portable structures a cost-effective solution?
                                </button>
                            </h2>
                            <div id="faq7" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Yes. Compared to traditional construction, our solutions significantly lower costs in labor, time, and materials—while maintaining high standards of quality, comfort, and safety.
                                </div>
                            </div>
                        </div>

                        <!-- Q8 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq8">
                                    How can I contact BESTCHOICE Contracting for inquiries or quotations?
                                </button>
                            </h2>
                            <div id="faq8" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    You can reach us through the following channels:<br><br>
                                    <ul class="list-unstyled">
                                        <li class="mb-2"><i class="bi bi-envelope-fill text-warning me-2"></i> Email: <a href="mailto:info@bestchoiceqatar.net" class="text-dark text-decoration-none">info@bestchoiceqatar.net</a></li>
                                        <li class="mb-2"><i class="bi bi-telephone-fill text-warning me-2"></i> Phone / WhatsApp: <a href="tel:+97450307568" class="text-dark text-decoration-none">+974 5030 7568</a></li>
                                        <li class="mb-2"><i class="bi bi-whatsapp text-success me-2"></i> WhatsApp: <a href="https://wa.me/97450307568" target="_blank" class="text-dark text-decoration-none">Chat with us</a></li>
                                        <li class="mb-2"><i class="bi bi-globe text-primary me-2"></i> Website: <a href="https://www.bestchoiceqatar.net" target="_blank" class="text-dark text-decoration-none">www.bestchoiceqatar.net</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Q9 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq9">
                                    How durable and reliable are BESTCHOICE portable cabins?
                                </button>
                            </h2>
                            <div id="faq9" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Our cabins are built with top-grade materials and engineered for long-term use in Qatar’s extreme conditions. They’re weather-resistant, low-maintenance, and crafted to last through years of heavy use.
                                </div>
                            </div>
                        </div>

                        <!-- Q10 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq10">
                                    How quickly can you deliver and install a portable cabin?
                                </button>
                            </h2>
                            <div id="faq10" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Our streamlined production and logistics process enables us to deliver and install units quickly—often within a few weeks. Prefabrication drastically reduces on-site construction time.
                                </div>
                            </div>
                        </div>

                        <!-- Q11 -->
                        <div class="accordion-item" data-aos="fade-up">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq11">
                                    Are your cabins eco-friendly and energy efficient?
                                </button>
                            </h2>
                            <div id="faq11" class="accordion-collapse collapse" data-bs-parent="#faqPageAccordion">
                                <div class="accordion-body">
                                    Absolutely. Our units use energy-efficient insulation, sustainable materials, and can include features like solar panels or low-energy lighting to reduce environmental impact.
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="col-lg-4">
                    <aside class="faq-sidebar" data-aos="fade-left">
                        <h3>Still Have Questions?</h3>
                        <p class="mb-4 opacity-75">If you couldn't find the answer you were looking for, our specialists are ready to assist you with technical details and customized quotations.</p>
                        
                        <div class="contact-item">
                            <i class="bi bi-telephone-fill"></i>
                            <div>
                                <h5>Call/WhatsApp Us</h5>
                                <p><a href="tel:+97450307568">+974 5030 7568</a></p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <i class="bi bi-envelope-fill"></i>
                            <div>
                                <h5>Email Support</h5>
                                <p><a href="mailto:info@bestchoiceqatar.net">info@bestchoiceqatar.net</a></p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <i class="bi bi-geo-alt-fill"></i>
                            <div>
                                <h5>Visit Our Office</h5>
                                <p>Doha, Qatar</p>
                            </div>
                        </div>

                        <div class="mt-4 pt-2">
                            <a href="/contact" class="btn btn-warning w-100 fw-bold py-3 text-uppercase rounded-0">Get a Free Quote</a>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </section>
</main>
