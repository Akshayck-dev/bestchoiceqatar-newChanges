
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Login | Bestchoice</title>
    <link href="~/Assets/icon/favicon.png" rel="icon" type="image/png">
    <link href="https://fonts.googleapis.com/css?family=Roboto:400,300,100,500,700,900" rel="stylesheet" type="text/css">
    <link href="~/Areas/backend/assets/css/bootstrap.css" rel="stylesheet" type="text/css">
    <link href="~/Areas/backend/assets/css/icons/icomoon/styles.css" rel="stylesheet" type="text/css">
    <link href="~/Areas/backend/assets/plugins/bootstrap-toastr/toastr.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Areas/backend/assets/css/styles.css" rel="stylesheet" type="text/css">
    <link href="~/Areas/backend/assets/css/theme.css" rel="stylesheet" type="text/css">
    <style type="text/css">
        .has-feedback label ~ .form-control-feedback {
            top: 0;
        }

        .form-control.error {
            border: 1px solid red !important;
        }

        label.error {
            color: red;
        }
    </style>
   
</head>
<body class="login-cover">
    <div class="page-container login-container">
        <div class="page-content">
            <div class="content-wrapper" style="color: #fdfbf6;">
                <div class="content" style="color: #fdfbf6;">
                    <input type="hidden" name="Email" value="@Request.QueryString["email"]" />
                    <form action="" method="post" >
                        <div class="panel panel-body login-form width-400">
                            <div class="text-center">
                                <img class="login-img" src="~/Content/assets/img/logo/animation.gif" />
                                <h5 class="content-group">Login to your account</h5>
                            </div>
                            <div class="form-group has-feedback has-feedback-left">
                                <input type="text" class="form-control" placeholder="Email" name="username" required />
                                <div class="form-control-feedback">
                                    <i class="icon-user text-muted"></i>
                                </div>
                            </div>
                            <div class="form-group has-feedback has-feedback-left">
                                <input type="password" class="form-control" placeholder="Password" name="password" required />
                                <div class="form-control-feedback">
                                    <i class="icon-lock2 text-muted"></i>
                                </div>
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-block" style="font-weight: bold; text-transform: uppercase;">Login<i class="icon-square-left position-right"></i></button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script type="text/javascript" src="/areas/backend/assets/js/jquery.min.js"></script>
    <script type="text/javascript" src="/areas/backend/assets/js/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/Scripts/jquery.validate.min.js"></script>
    <script src="http://cdn.jsdelivr.net/jquery.validation/1.15.0/additional-methods.min.js"></script>
    <script type="text/javascript" src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <script type="text/javascript" src="~/areas/backend/assets/js/scripts.js"></script>
    <script src="~/Areas/backend/assets/js/app.js" type="text/javascript"></script>
    <script src="~/Areas/backend/assets/js/jquery.livequery.js" type="text/javascript"></script>
    <script src="~/Areas/backend/assets/plugins/bootstrap-toastr/toastr.min.js" type="text/javascript"></script>
    <script src="~/Areas/backend/assets/js/jquery.cookie.min.js" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-backstretch/2.0.4/jquery.backstretch.min.js"></script>
    <script src="~/Scripts/app.js" type="text/javascript"></script>
    <script>
        $(document).ready(function () {
            App.init();
            @{
                    if (TempData["Notification"] != null)
                    {
                        Notification notification = (Notification)TempData["Notification"];
                        <text>WebApp.Notifications.Show('@notification.Type', '@notification.Text');</text>
                    }
                 }
        });
        $.backstretch([
      "/areas/backend/assets/images/bg-2.jpg"
    , "/areas/backend/assets/images/bg-3.jpg"
    , "/areas/backend/assets/images/bg-4.jpg"
        ], { duration: 3000, fade: 750 });
    </script>

</body>
</html>
