@model BestChoiceQatar.Models.ChangePassword
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Areas/Backend/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title">
            <h4><span class="text-semibold">Change Password</span></h4>
        </div>
    </div>
    <div class="breadcrumb-line">
        <ul class="breadcrumb">
            <li><a href="/backend/default/dashboard"><i class="icon-home4 position-left"></i>Dashboard</a></li>            
            <li class="active">Change Password</li>
        </ul>
    </div>
</div>

<div class="content">
    <form method="post" class="form-horizontal form_validation" action="" data-type="ChangePassword" enctype="multipart/form-data">
        <div class="panel panel-flat">
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-12">

                        <div class="form-group">
                            <label class="col-lg-2 control-label">New&nbsp;Password</label>
                            <div class="col-lg-7">
                                @Html.PasswordFor(model => model.Password, new { @placeholder = "Please enter the Password", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="col-lg-2 control-label">Confirm&nbsp;Password</label>
                            <div class="col-lg-7">
                                @Html.PasswordFor(model => model.ConfirmPassword, new { @placeholder = "Please re-enter the Password", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "text-danger" })
                            </div>
                        </div>

                    </div>
                </div>
                <hr>
                <div class="text-right">
                    <button class="btn btn-default" type="reset">Reset<i class="icon-reload-alt position-right"></i></button>
                    <button type="submit" class="btn btn-primary">Submit <i class="icon-arrow-right14 position-right"></i></button>
                </div>
            </div>
        </div>
    </form>

</div>


