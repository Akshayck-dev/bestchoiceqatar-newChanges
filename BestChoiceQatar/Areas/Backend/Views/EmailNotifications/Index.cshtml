@model BgmConsultancy.Models.Registration
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Backend/Views/Shared/_Layout.cshtml";
}

@section JavaScript{
    <script type="text/javascript">$(document).ready(function () { WebApp.Core.HighlightCurrentMenuItem('Email Notifications') });</script>
}

<div class="page-header">
    <div class="page-header-content">

        <div class="page-title">
            <h4><span class="text-semibold">Send Email Notifications</span></h4>
        </div>
        <div class="heading-elements">
            <div class="heading-btn-group">
                <a class="btn btn-link btn-float has-text" href="/backend/brochures/index"><i class="icon-user-lock"></i><span>All Brochures</span></a>
            </div>
        </div>
    </div>   
</div>
<div class="content">
    <form method="post" class="form-horizontal" action="" enctype="multipart/form-data" autocomplete="off">
        <div class="panel panel-flat">
            <div class="panel-body">
                <div class="row">
                    <div class="col-lg-12">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group">
                            <label class="col-lg-3 control-label">Email(s)</label>
                            <div class="col-lg-7">
                                <input type="text" name="Emails" data-multiple="true" id="EmailID" class="form-control autocomplete" data-source="/backend/Registrations/GetEmails" placeholder="Please Select the Email" data-val="true" data-val-required="Please select an Email" />
                                <label for="chk_all_emails"><input type="checkbox" id="chk_all_emails" name="chk_all_emails" /> Select All</label>
                                @Html.ValidationMessageFor(model => model.Emails, "", new { @class = "text-danger" })
                            </div>
                        </div>                       
                    </div>
                </div>
                <hr>
                <div class="text-center">
                    <a href="/backend/EmailNotifications" class="btn btn-default">Cancel<i class="icon-reload-alt position-right"></i> </a>
                    <button type="submit" class="btn btn-primary">Send Email <i class="icon-arrow-right14 position-right"></i></button>
                </div>
            </div>
        </div>
    </form>
</div>




