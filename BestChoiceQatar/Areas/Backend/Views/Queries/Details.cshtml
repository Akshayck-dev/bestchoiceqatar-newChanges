@model BestChoiceQatar.Models.Enquiry
@{
    ViewBag.Title = "Details";
    Layout = "~/Areas/Backend/Views/Shared/_Layout.cshtml";
}

@section JavaScript{
    <script type="text/javascript">$(document).ready(function () { WebApp.Core.HighlightCurrentMenuItem('Enquiries') });</script>
}

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title">
            <h4><span class="text-semibold">Enquiry Details</span></h4>
        </div>
        <div class="heading-elements">
            <div class="heading-btn-group">
            </div>
        </div>
    </div>
    <div class="breadcrumb-line">
        <ul class="breadcrumb">
            <li><a href="/backend/default/dashboard"><i class="icon-home4 position-left"></i>Dashboard</a></li>
            <li><a href="/backend/queries/index">Enquiry</a></li>

            <li class="active">Enquiry Details</li>
        </ul>
    </div>
</div>
<div class="content">
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-flat">
                <div class="panel-body">
                    <div class="row">

                        <div class="col-md-12">
                            <div class="main">
                                <table class="table table-borderless table-xs content-group-sm">
                                    <tbody>
                                        <tr>
                                            <td class="col-lg-3">@Html.DisplayNameFor(model => model.FullName)</td>
                                            <td class="col-lg-1">:</td>
                                            <td> @Model.FullName</td>
                                        </tr>
                                        <tr>
                                            <td class="col-lg-3">@Html.DisplayNameFor(model => model.Email)</td>
                                            <td class="col-lg-1">:</td>
                                            <td> @Model.Email</td>
                                        </tr>
                                        <tr>
                                            <td class="col-lg-3">@Html.DisplayNameFor(model => model.ContactNumber)</td>
                                            <td class="col-lg-1">:</td>
                                            <td> @Model.ContactNumber</td>
                                        </tr>
                                        <tr>
                                            <td class="col-lg-3">@Html.DisplayNameFor(model => model.Subject)</td>
                                            <td class="col-lg-1">:</td>
                                            <td> @Model.Subject</td>
                                        </tr>
                                        <tr>
                                            <td class="col-lg-3">@Html.DisplayNameFor(model => model.Message)</td>
                                            <td class="col-lg-1">:</td>
                                            <td> @Model.Message</td>
                                        </tr>
                                        @*<tr>
                                            <td class="col-lg-3">@Html.DisplayNameFor(model => model.ContactType)</td>
                                            <td class="col-lg-1">:</td>
                                            <td> @Model.ContactType</td>
                                        </tr>*@
                                        <tr>
                                            <td class="col-lg-3">@Html.DisplayNameFor(model => model.CreatedOn)</td>
                                            <td class="col-lg-1">:</td>
                                            <td> @Model.CreatedOn.ToString("dd/MM/yyyy hh:mm ss")</td>
                                        </tr>

                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>

