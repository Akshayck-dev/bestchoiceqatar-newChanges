@model BestChoiceQatar.Models.Setting
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Backend/Views/Shared/_Layout.cshtml";
}
@section JavaScript{

    <script type="text/javascript">$(document).ready(function () { WebApp.Core.HighlightCurrentMenuItem('Settings') });</script>
}


<div class="page-header">
    <div class="page-header-content">
        <div class="page-title">
            <h4><span class="text-semibold">General Settings</span></h4>
        </div>
        <div class="heading-elements">
            <div class="heading-btn-group">

            </div>
        </div>
    </div>
    <div class="breadcrumb-line">
        <ul class="breadcrumb">
            @*<li><a href="/default/dashboard"><i class="icon-home position-left"></i>Dashboard</a></li>*@

            <li class="active">General Settings</li>
        </ul>
    </div>
</div>

<div class="content">
    <form method="post" class="form-horizontal" action="" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="panel panel-flat">
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.IntroText)</label>
                            <div class="col-lg-7">
                                @Html.TextAreaFor(model => model.IntroText, 5,11,new { @placeholder = "Please enter the Popup Text", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.IntroText, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Location)</label>
                            <div class="col-lg-7">
                                @Html.TextBoxFor(model => model.Location, new { @placeholder = "Please enter Location", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Location, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Email):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.Email, new { @placeholder = "Please enter the Email", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Mobile1):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.Mobile1, new { @placeholder = "Please enter the Primary Mobile Number", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Mobile1, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Mobile2):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.Mobile2, new { @placeholder = "Please enter the Secondary Mobile Number", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Mobile1, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Whatsup):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.Whatsup, new { @placeholder = "Please enter the Whatsapp link", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Whatsup, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Instagram):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.Instagram, new { @placeholder = "Please enter the Instagram link", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Instagram, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Facebook):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.Facebook, new { @placeholder = "Please enter the Facebook link", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Facebook, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.Twitter):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.Twitter, new { @placeholder = "Please enter the Twitter link", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.Twitter, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.LinkedIn):</label>
                            <div class="col-lg-7">

                                @Html.TextBoxFor(model => model.LinkedIn, new { @placeholder = "Please enter the LinkedIn link", @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.LinkedIn, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.AboutText):</label>
                            <div class="col-lg-7">

                                @Html.TextAreaFor(model => model.AboutText, new { @placeholder = "Please enter the About Text", @class = "form-control html-editor" })
                                @Html.ValidationMessageFor(model => model.AboutText, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-3 control-label">@Html.DisplayNameFor(model => model.HompageIntroText):</label>
                            <div class="col-lg-7">

                                @Html.TextAreaFor(model => model.HompageIntroText, new { @placeholder = "Please enter the Hompage Text", @class = "form-control html-editor" })
                                @Html.ValidationMessageFor(model => model.HompageIntroText, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div>
                <hr>
                <div class="text-right">
                    <a href="/backend/settings" class="btn btn-default">Reset<i class="icon-reload-alt position-right"></i> </a>
                    <button type="submit" class="btn btn-primary">Submit <i class="icon-arrow-right14 position-right"></i></button>
                </div>
            </div>
        </div>
    </form>
</div>


